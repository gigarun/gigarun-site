---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = 'Gigarun — DSI Externalisé à La Réunion',
  description = 'Infogérance IT, ERP Dolibarr, cybersécurité pour PME réunionnaises. 15 ans d\'expérience, interlocuteur unique, intervention en 4h.'
} = Astro.props;
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;1,9..40,400&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #07001C;
      --accent: #7C3AED;
      --cyan: #06B6D4;
      --text: #F1F0F7;
      --muted: #9B99AA;
      --surface: #110833;
    }
    html { scroll-behavior: smooth; }
    body { background-color: var(--bg); color: var(--text); font-family: 'DM Sans', sans-serif; }
    .font-syne { font-family: 'Syne', sans-serif; }
    h1, h2, h3 { font-family: 'Syne', sans-serif; }
  </style>
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
  <CookieBanner />
</body>
</html>
