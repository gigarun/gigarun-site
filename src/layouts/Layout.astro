---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = 'Gigarun — DSI Externalisé à La Réunion',
  description = 'Infogérance IT, ERP Dolibarr, cybersécurité pour PME réunionnaises. 15 ans d\'expérience, interlocuteur unique, intervention en 4h.'
} = Astro.props;

const _segs = Astro.url.pathname.split('/').filter(Boolean);
const _tc = (x) => decodeURIComponent(x).replace(/-/g,' ').replace(/(^|\s)\S/g, c => c.toUpperCase());
let _acc = '';
const _items = [{ '@type':'ListItem', position:1, name:'Accueil', item:'https://gigarun.re/' }];
_segs.forEach((sg,i)=>{ _acc += '/'+sg; _items.push({ '@type':'ListItem', position:i+2, name:_tc(sg), item:'https://gigarun.re'+_acc }); });
const breadcrumbLd = { '@context':'https://schema.org', '@type':'BreadcrumbList', itemListElement:_items };
const localBusinessLd = { '@context':'https://schema.org', '@type':'ProfessionalService', name:'Gigarun', image:'https://gigarun.re/favicon.ico', '@id':'https://gigarun.re', url:'https://gigarun.re', telephone:'+262692311191', priceRange:'EUR', address:{ '@type':'PostalAddress', streetAddress:'7 rue du Temple, ZAC Ocean Indien', addressLocality:'Saint-Pierre', postalCode:'97410', addressRegion:'La Reunion', addressCountry:'RE' }, geo:{ '@type':'GeoCoordinates', latitude:-21.3379483, longitude:55.4829232 }, areaServed:{ '@type':'AdministrativeArea', name:'La Reunion' }, openingHoursSpecification:{ '@type':'OpeningHoursSpecification', dayOfWeek:['Monday','Tuesday','Wednesday','Thursday','Friday'], opens:'08:00', closes:'18:00' } };
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;1,9..40,400&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #07001C;
      --accent: #7C3AED;
      --cyan: #06B6D4;
      --text: #F1F0F7;
      --muted: #9B99AA;
      --surface: #110833;
    }
    html { scroll-behavior: smooth; }
    body { background-color: var(--bg); color: var(--text); font-family: 'DM Sans', sans-serif; }
    .font-syne { font-family: 'Syne', sans-serif; }
    h1, h2, h3 { font-family: 'Syne', sans-serif; }
  </style>
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessLd)} />
  {_segs.length > 0 && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />}
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
  <CookieBanner />
</body>
</html>
