---
---
<footer class="bg-[#03000F] pt-16 pb-8" style="border-top:1px solid rgba(124,58,237,0.15);">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">

      <!-- Col 1 : Brand -->
      <div>
        <a href="/" class="font-syne font-extrabold tracking-wider text-[#F1F0F7] block mb-2" style="font-size:20px;">
          GIGARUN<span class="text-[#7C3AED]">.</span>
        </a>
        <p class="text-[#9B99AA] text-sm leading-relaxed mb-5">DSI externalisé pour PME réunionnaises</p>
        <div class="flex flex-col gap-y-2">
          <a href="tel:+262692311191" class="text-[#9B99AA] hover:text-[#F1F0F7] text-sm transition-colors">0692 31 11 91</a>
          <a href="https://t.me/gigarun" target="_blank" rel="noopener" class="text-[#9B99AA] hover:text-[#F1F0F7] text-sm transition-colors flex items-center gap-1.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221l-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12L7.088 13.56l-2.95-.924c-.64-.203-.654-.64.136-.954l11.566-4.458c.537-.194 1.006.131.054.997z"/></svg>
            Telegram @gigarun
          </a>
          <a href="/contact" class="text-[#9B99AA] hover:text-[#F1F0F7] text-sm transition-colors">Formulaire de contact</a>
          <p class="text-[#9B99AA] text-sm">7 rue du Temple, Saint-Pierre</p>
          <a href="https://www.cyber-reunion.fr/cartographie-offreurs/" target="_blank" rel="noopener" class="inline-block mt-4">
            <img src="/bloc_cyber_reunion.webp" alt="Référencé sur la plateforme Cybermalveillance" width="160" class="opacity-90 hover:opacity-100 transition-opacity" />
          </a>
        </div>
      </div>

      <!-- Col 2 : Services -->
      <div>
        <h4 class="text-[12px] uppercase tracking-widest text-[#7C3AED] font-semibold mb-4">Services</h4>
        <ul class="flex flex-col gap-y-2.5">
          <li><a href="/infogerance" class="text-[#9B99AA] hover:text-[#F1F0F7] text-sm transition-colors">Infogérance</a></li>
          <li><a href="/securite" class="text-[#9B99AA] hover:text-[#F1F0F7] text-sm transition-colors">Cybersécurité</a></li>
          <li><a href="/pentest" class="text-[#9B99AA] hover:text-[#F1F0F7] text-sm transition-colors">Pentest</a></li>
          <li><a href="/audit" class="text-[#9B99AA] hover:text-[#F1F0F7] text-sm transition-colors">Audit informatique</a></li>
          <li><a href="/reseau" class="text-[#9B99AA] hover:text-[#F1F0F7] text-sm transition-colors">Réseau &amp; infrastructure</a></li>
          <li><a href="/sauvegarde-pra" class="text-[#9B99AA] hover:text-[#F1F0F7] text-sm transition-colors">Sauvegarde &amp; PRA</a></li>
          <li><a href="/cloud" class="text-[#9B99AA] hover:text-[#F1F0F7] text-sm transition-colors">Cloud managé</a></li>
          <li><a href="/telephonie" class="text-[#9B99AA] hover:text-[#F1F0F7] text-sm transition-colors">Téléphonie IP</a></li>
        </ul>
      </div>

      <!-- Col 3 : Solutions + Entreprise -->
      <div>
        <h4 class="text-[12px] uppercase tracking-widest text-[#7C3AED] font-semibold mb-4">Solutions</h4>
        <ul class="flex flex-col gap-y-2.5 mb-8">
          <li><a href="/dolibarr" class="text-[#9B99AA] hover:text-[#F1F0F7] text-sm transition-colors">Dolibarr ERP</a></li>
          <li><a href="/microsoft-365" class="text-[#9B99AA] hover:text-[#F1F0F7] text-sm transition-colors">Microsoft 365</a></li>
          <li><a href="/location-materiel" class="text-[#9B99AA] hover:text-[#F1F0F7] text-sm transition-colors">Location matériel</a></li>
          <li><a href="/creation-site" class="text-[#9B99AA] hover:text-[#F1F0F7] text-sm transition-colors">Création de site web</a></li>
          <li><a href="/intelligence-artificielle" class="text-[#9B99AA] hover:text-[#F1F0F7] text-sm transition-colors">Intelligence artificielle</a></li>
        </ul>
        <h4 class="text-[12px] uppercase tracking-widest text-[#7C3AED] font-semibold mb-4">Entreprise</h4>
        <ul class="flex flex-col gap-y-2.5">
          <li><a href="/a-propos" class="text-[#9B99AA] hover:text-[#F1F0F7] text-sm transition-colors">À propos</a></li>
          <li><a href="/blog" class="text-[#9B99AA] hover:text-[#F1F0F7] text-sm transition-colors">Blog</a></li>
          <li><a href="/contact" class="text-[#9B99AA] hover:text-[#F1F0F7] text-sm transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Col 4 : Légal -->
      <div>
        <h4 class="text-[12px] uppercase tracking-widest text-[#7C3AED] font-semibold mb-4">Informations légales</h4>
        <ul class="flex flex-col gap-y-2.5">
          <li><a href="/mentions-legales" class="text-[#9B99AA] hover:text-[#F1F0F7] text-sm transition-colors">Mentions légales</a></li>
          <li><a href="/confidentialite" class="text-[#9B99AA] hover:text-[#F1F0F7] text-sm transition-colors">Politique de confidentialité</a></li>
          <li><a href="/cgv" class="text-[#9B99AA] hover:text-[#F1F0F7] text-sm transition-colors">CGV &amp; Services</a></li>
          <li><a href="/cgl" class="text-[#9B99AA] hover:text-[#F1F0F7] text-sm transition-colors">CGL Location</a></li>
        </ul>
        <div class="mt-8">
          <div class="inline-flex items-center gap-2 bg-[#0D0028] border border-[rgba(124,58,237,0.2)] px-3 py-1.5 rounded-lg">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
            <span class="text-[#9B99AA] text-xs">RGPD conforme</span>
          </div>
        </div>
      </div>

    </div>

    <!-- Barre bas -->
    <div class="pt-6 flex flex-col sm:flex-row items-center justify-between gap-3" style="border-top:1px solid rgba(124,58,237,0.1);">
      <p class="text-[#9B99AA] text-[12px]">&copy; 2025 Gigarun &middot; Tous droits réservés &middot; SIRET 504 015 181 00044</p>
      <div class="flex items-center gap-4">
        <a href="/mentions-legales" class="text-[#9B99AA] hover:text-[#F1F0F7] text-[12px] transition-colors">Mentions légales</a>
        <span class="text-[rgba(155,153,170,0.3)] text-[12px]">&middot;</span>
        <a href="/confidentialite" class="text-[#9B99AA] hover:text-[#F1F0F7] text-[12px] transition-colors">Confidentialité</a>
        <span class="text-[rgba(155,153,170,0.3)] text-[12px]">&middot;</span>
        <a href="/cgv" class="text-[#9B99AA] hover:text-[#F1F0F7] text-[12px] transition-colors">CGV</a>
        <span class="text-[rgba(155,153,170,0.3)] text-[12px]">&middot;</span>
        <a href="/cgl" class="text-[#9B99AA] hover:text-[#F1F0F7] text-[12px] transition-colors">CGL</a>
      </div>
    </div>
  </div>
</footer>
