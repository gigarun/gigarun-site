                  <div class="text-[#9B99AA] text-xs mt-0.5 leading-relaxed">Pilotage IT externalisé, supervision 24/7</div>
                </div>
              </a>

              <a href="/securite" class="flex items-start gap-3 p-3 rounded-xl hover:bg-[rgba(124,58,237,0.1)] transition-colors group/item">
