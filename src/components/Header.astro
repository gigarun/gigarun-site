---
---
<header class="fixed top-0 left-0 right-0 z-50 bg-[#07001C]/85 backdrop-blur-md border-b border-[rgba(124,58,237,0.15)]">
  <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="font-syne font-extrabold tracking-wider text-[#F1F0F7]" style="font-size:20px;">
      GIGARUN<span class="text-[#7C3AED]">.</span>
    </a>

    <!-- Nav desktop -->
    <nav class="hidden md:flex items-center gap-6">

      <!-- Services dropdown -->
      <div class="relative group">
        <button class="flex items-center gap-1 text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] transition-colors text-[21px] font-medium">
          Services
          <svg class="w-3 h-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="absolute top-full left-0 mt-2 w-64 bg-[#110833] border border-[rgba(124,58,237,0.25)] rounded-xl shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 py-2">
          <a href="/infogerance" class="block px-4 py-2 text-sm text-[rgba(241,240,247,0.8)] hover:text-[#F1F0F7] hover:bg-[rgba(124,58,237,0.1)]">Infogérance</a>
          <a href="/securite" class="block px-4 py-2 text-sm text-[rgba(241,240,247,0.8)] hover:text-[#F1F0F7] hover:bg-[rgba(124,58,237,0.1)]">Cybersécurité</a>
          <a href="/pentest" class="block px-4 py-2 text-sm text-[rgba(241,240,247,0.8)] hover:text-[#F1F0F7] hover:bg-[rgba(124,58,237,0.1)]">Pentest & NIS2</a>
          <a href="/audit" class="block px-4 py-2 text-sm text-[rgba(241,240,247,0.8)] hover:text-[#F1F0F7] hover:bg-[rgba(124,58,237,0.1)]">Audit informatique</a>
          <a href="/reseau" class="block px-4 py-2 text-sm text-[rgba(241,240,247,0.8)] hover:text-[#F1F0F7] hover:bg-[rgba(124,58,237,0.1)]">Réseau</a>
          <a href="/sauvegarde-pra" class="block px-4 py-2 text-sm text-[rgba(241,240,247,0.8)] hover:text-[#F1F0F7] hover:bg-[rgba(124,58,237,0.1)]">Sauvegarde & PRA</a>
          <a href="/hebergement" class="block px-4 py-2 text-sm text-[rgba(241,240,247,0.8)] hover:text-[#F1F0F7] hover:bg-[rgba(124,58,237,0.1)]">Hébergement cloud</a>
          <a href="/cloud" class="block px-4 py-2 text-sm text-[rgba(241,240,247,0.8)] hover:text-[#F1F0F7] hover:bg-[rgba(124,58,237,0.1)]">Cloud souverain</a>
          <a href="/telephonie" class="block px-4 py-2 text-sm text-[rgba(241,240,247,0.8)] hover:text-[#F1F0F7] hover:bg-[rgba(124,58,237,0.1)]">Téléphonie IP</a>
          <a href="/location-materiel" class="block px-4 py-2 text-sm text-[rgba(241,240,247,0.8)] hover:text-[#F1F0F7] hover:bg-[rgba(124,58,237,0.1)]">Location matériel</a>
          <a href="/creation-site" class="block px-4 py-2 text-sm text-[rgba(241,240,247,0.8)] hover:text-[#F1F0F7] hover:bg-[rgba(124,58,237,0.1)]">Création de site</a>
          <a href="/intelligence-artificielle" class="block px-4 py-2 text-sm text-[rgba(241,240,247,0.8)] hover:text-[#F1F0F7] hover:bg-[rgba(124,58,237,0.1)]">Intelligence artificielle</a>
        </div>
      </div>

      <!-- Solutions dropdown -->
      <div class="relative group">
        <button class="flex items-center gap-1 text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] transition-colors text-[21px] font-medium">
          Solutions
          <svg class="w-3 h-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="absolute top-full left-0 mt-2 w-64 bg-[#110833] border border-[rgba(124,58,237,0.25)] rounded-xl shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 py-2">
          <a href="/dolibarr" class="block px-4 py-2 text-sm text-[rgba(241,240,247,0.8)] hover:text-[#F1F0F7] hover:bg-[rgba(124,58,237,0.1)]">Dolibarr ERP/CRM</a>
          <a href="/microsoft-365" class="block px-4 py-2 text-sm text-[rgba(241,240,247,0.8)] hover:text-[#F1F0F7] hover:bg-[rgba(124,58,237,0.1)]">Microsoft 365</a>
          <a href="/infogerance-la-reunion" class="block px-4 py-2 text-sm text-[rgba(241,240,247,0.8)] hover:text-[#F1F0F7] hover:bg-[rgba(124,58,237,0.1)]">Infogérance La Réunion</a>
          <a href="/informaticien-la-reunion" class="block px-4 py-2 text-sm text-[rgba(241,240,247,0.8)] hover:text-[#F1F0F7] hover:bg-[rgba(124,58,237,0.1)]">Informaticien La Réunion</a>
          <a href="/maintenance-tpe" class="block px-4 py-2 text-sm text-[rgba(241,240,247,0.8)] hover:text-[#F1F0F7] hover:bg-[rgba(124,58,237,0.1)]">Maintenance TPE</a>
          <a href="/audit-entreprise" class="block px-4 py-2 text-sm text-[rgba(241,240,247,0.8)] hover:text-[#F1F0F7] hover:bg-[rgba(124,58,237,0.1)]">Audit entreprise</a>
        </div>
      </div>

      <a href="/a-propos" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] transition-colors text-[21px] font-medium">À propos</a>
      <a href="/blog" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] transition-colors text-[21px] font-medium">Blog</a>
      <a href="/contact" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] transition-colors text-[21px] font-medium">Contact</a>
    </nav>

    <!-- CTA pill -->
    <div class="hidden md:flex">
      <a href="/contact" class="bg-[#7C3AED] hover:bg-[#6D28D9] text-white text-sm font-medium px-5 py-2 transition-colors" style="border-radius:9999px;">
        Diagnostic gratuit
      </a>
    </div>

    <!-- Hamburger -->
    <label class="md:hidden cursor-pointer" for="menu-toggle">
      <svg class="w-6 h-6 text-[#F1F0F7]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </label>
  </div>

  <!-- Mobile menu -->
  <input type="checkbox" id="menu-toggle" class="hidden peer"/>
  <div class="hidden peer-checked:block md:!hidden bg-[#110833] border-t border-[rgba(124,58,237,0.2)] px-6 py-4">
    <nav class="flex flex-col gap-1">
      <div class="text-[#7C3AED] text-xs font-semibold uppercase tracking-wider px-1 py-2 mt-2">Services</div>
      <a href="/infogerance" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] text-sm py-1.5 px-1">Infogérance</a>
      <a href="/securite" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] text-sm py-1.5 px-1">Cybersécurité</a>
      <a href="/pentest" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] text-sm py-1.5 px-1">Pentest & NIS2</a>
      <a href="/audit" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] text-sm py-1.5 px-1">Audit informatique</a>
      <a href="/reseau" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] text-sm py-1.5 px-1">Réseau</a>
      <a href="/sauvegarde-pra" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] text-sm py-1.5 px-1">Sauvegarde & PRA</a>
      <a href="/hebergement" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] text-sm py-1.5 px-1">Hébergement cloud</a>
      <a href="/cloud" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] text-sm py-1.5 px-1">Cloud souverain</a>
      <a href="/telephonie" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] text-sm py-1.5 px-1">Téléphonie IP</a>
      <a href="/location-materiel" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] text-sm py-1.5 px-1">Location matériel</a>
      <a href="/creation-site" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] text-sm py-1.5 px-1">Création de site</a>
      <a href="/intelligence-artificielle" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] text-sm py-1.5 px-1">Intelligence artificielle</a>
      <div class="text-[#7C3AED] text-xs font-semibold uppercase tracking-wider px-1 py-2 mt-3">Solutions</div>
      <a href="/dolibarr" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] text-sm py-1.5 px-1">Dolibarr ERP/CRM</a>
      <a href="/microsoft-365" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] text-sm py-1.5 px-1">Microsoft 365</a>
      <a href="/infogerance-la-reunion" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] text-sm py-1.5 px-1">Infogérance La Réunion</a>
      <a href="/informaticien-la-reunion" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] text-sm py-1.5 px-1">Informaticien La Réunion</a>
      <a href="/maintenance-tpe" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] text-sm py-1.5 px-1">Maintenance TPE</a>
      <a href="/audit-entreprise" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] text-sm py-1.5 px-1">Audit entreprise</a>
      <div class="border-t border-[rgba(124,58,237,0.2)] my-3"></div>
      <a href="/a-propos" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] text-sm py-1.5 px-1">À propos</a>
      <a href="/blog" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] text-sm py-1.5 px-1">Blog</a>
      <a href="/contact" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] text-sm py-1.5 px-1">Contact</a>
      <a href="/contact" class="bg-[#7C3AED] text-white text-sm font-medium px-5 py-2 text-center mt-3" style="border-radius:9999px;">
        Diagnostic gratuit
      </a>
    </nav>
  </div>
</header>
