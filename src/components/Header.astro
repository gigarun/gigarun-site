    <div class="max-w-7xl mx-auto px-6 h-14 flex items-center justify-between">

      <!-- Logo -->
      <a href="/" class="flex items-baseline gap-2.5 flex-shrink-0">
        <span class="font-syne font-extrabold tracking-wider text-[#F1F0F7] text-xl">GIGARUN<span class="text-[#7C3AED]">.</span></span>
        <span class="hidden lg:block text-[#9B99AA] text-xs font-medium tracking-wide border-l border-[rgba(255,255,255,0.15)] pl-2.5">Vos m&eacute;tiers, nos solutions</span>
      </a>

      <!-- Nav desktop -->
      <nav class="hidden lg:flex items-center gap-7">

        <a href="/" class="text-sm font-medium text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] transition-colors">Accueil</a>

        <!-- Mega-menu Services -->
        <div class="relative group">
          <button class="flex items-center gap-1 text-sm font-medium text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] transition-colors py-4">
            Services
