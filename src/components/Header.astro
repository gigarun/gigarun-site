---
---
<header class="fixed top-0 left-0 right-0 z-50 bg-[#07001C]/85 backdrop-blur-md border-b border-[rgba(124,58,237,0.15)]">
  <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="font-syne font-extrabold tracking-wider text-[#F1F0F7]" style="font-size:20px;">
      GIGARUN<span class="text-[#7C3AED]">.</span>
    </a>

    <!-- Nav desktop -->
    <nav class="hidden md:flex items-center gap-8">
      <a href="#services" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] transition-colors text-[15px] font-medium">Services</a>
      <a href="#tarifs" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] transition-colors text-[15px] font-medium">Tarifs</a>
      <a href="#contact" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] transition-colors text-[15px] font-medium">À propos</a>
      <a href="#contact" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] transition-colors text-[15px] font-medium">Contact</a>
    </nav>

    <!-- CTA pill -->
    <div class="hidden md:flex">
      <a href="#contact" class="bg-[#7C3AED] hover:bg-[#6D28D9] text-white text-[15px] font-medium px-5 py-2 transition-colors" style="border-radius:9999px;">
        Diagnostic gratuit
      </a>
    </div>

    <!-- Hamburger -->
    <label class="md:hidden cursor-pointer" for="menu-toggle">
      <svg class="w-6 h-6 text-[#F1F0F7]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </label>
  </div>

  <!-- Mobile menu -->
  <input type="checkbox" id="menu-toggle" class="hidden peer"/>
  <div class="hidden peer-checked:block md:!hidden bg-[#110833] border-t border-[rgba(124,58,237,0.2)] px-6 py-4">
    <nav class="flex flex-col gap-4">
      <a href="#services" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] transition-colors text-[15px] font-medium">Services</a>
      <a href="#tarifs" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] transition-colors text-[15px] font-medium">Tarifs</a>
      <a href="#contact" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] transition-colors text-[15px] font-medium">À propos</a>
      <a href="#contact" class="text-[rgba(241,240,247,0.7)] hover:text-[#F1F0F7] transition-colors text-[15px] font-medium">Contact</a>
      <a href="#contact" class="bg-[#7C3AED] text-white text-[15px] font-medium px-5 py-2 text-center transition-colors" style="border-radius:9999px;">
        Diagnostic gratuit
      </a>
    </nav>
  </div>
</header>
