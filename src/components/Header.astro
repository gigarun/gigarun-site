---
---
<header class="fixed top-0 left-0 right-0 z-50 bg-[#07001C]/80 backdrop-blur-md border-b border-[rgba(124,58,237,0.2)]">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="font-syne font-extrabold text-xl tracking-wider text-[#F1F0F7]">
      GIGARUN<span class="text-[#7C3AED]">.</span>
    </a>

    <!-- Nav desktop -->
    <nav class="hidden md:flex items-center gap-8">
      <a href="#services" class="text-[#9B99AA] hover:text-[#F1F0F7] transition-colors text-base font-medium">Services</a>
      <a href="#dolibarr" class="text-[#9B99AA] hover:text-[#F1F0F7] transition-colors text-base font-medium">Dolibarr</a>
      <a href="#cybersecurite" class="text-[#9B99AA] hover:text-[#F1F0F7] transition-colors text-base font-medium">Cybersécurité</a>
      <a href="#contact" class="text-[#9B99AA] hover:text-[#F1F0F7] transition-colors text-base font-medium">Contact</a>
    </nav>

    <!-- CTA -->
    <div class="hidden md:flex">
      <a href="#contact" class="bg-[#7C3AED] hover:bg-[#6D28D9] text-white text-base font-medium px-5 py-3 rounded-lg transition-colors">
        Diagnostic gratuit
      </a>
    </div>

    <!-- Hamburger -->
    <label class="md:hidden cursor-pointer" for="menu-toggle">
      <svg class="w-6 h-6 text-[#F1F0F7]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </label>
  </div>

  <!-- Mobile menu -->
  <input type="checkbox" id="menu-toggle" class="hidden peer"/>
  <div class="hidden peer-checked:block md:!hidden bg-[#110833] border-t border-[rgba(124,58,237,0.2)] px-6 py-4">
    <nav class="flex flex-col gap-4">
      <a href="#services" class="text-[#9B99AA] hover:text-[#F1F0F7] transition-colors text-base font-medium">Services</a>
      <a href="#dolibarr" class="text-[#9B99AA] hover:text-[#F1F0F7] transition-colors text-base font-medium">Dolibarr</a>
      <a href="#cybersecurite" class="text-[#9B99AA] hover:text-[#F1F0F7] transition-colors text-base font-medium">Cybersécurité</a>
      <a href="#contact" class="text-[#9B99AA] hover:text-[#F1F0F7] transition-colors text-base font-medium">Contact</a>
      <a href="#contact" class="bg-[#7C3AED] text-white text-base font-medium px-5 py-3 rounded-lg text-center transition-colors">
        Diagnostic gratuit
      </a>
    </nav>
  </div>
</header>
