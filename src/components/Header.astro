          </button>
          <!-- Dropdown mega-menu -->
          <div class="absolute top-full left-1/2 -translate-x-1/2 mt-0 w-[640px] bg-[#0D0028] border border-[rgba(124,58,237,0.2)] rounded-2xl shadow-2xl shadow-[rgba(124,58,237,0.15)] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-2 group-hover:translate-y-0 p-5">
            <div class="grid grid-cols-2 gap-2 mb-4">

              <a href="/infogerance" class="flex items-start gap-3 p-3 rounded-xl hover:bg-[rgba(124,58,237,0.1)] transition-colors group/item">
