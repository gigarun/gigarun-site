---
---
<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" id="site-header">

  <!-- Barre d'info supérieure -->
  <div class="bg-[#7C3AED] text-white text-sm hidden md:block">
    <div class="max-w-7xl mx-auto px-6 h-9 flex items-center justify-between">
      <span class="text-white/80">DSI externalisé pour TPE/PME à La Réunion · Intervention sous 4h</span>
      <a href="tel:+262692311191" class="flex items-center gap-2 hover:text-white/80 transition-opacity font-medium">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
        0692 31 11 91
      </a>
    </div>
  </div>

  <!-- Nav principale -->
