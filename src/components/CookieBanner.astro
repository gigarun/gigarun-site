---
---
<div id="cookie-banner" style="position:fixed;bottom:0;left:0;right:0;z-index:9999;padding:1rem;pointer-events:none;opacity:0;transition:opacity 0.3s;">
  <div style="pointer-events:auto;max-width:56rem;margin:0 auto;background:#0D0028;border:1px solid rgba(124,58,237,0.35);border-radius:12px;padding:1.25rem 1.5rem;display:flex;flex-wrap:wrap;align-items:center;gap:1rem;box-shadow:0 -4px 32px rgba(0,0,0,0.5);">
    <div style="flex:1;min-width:200px;">
      <p style="color:#F1F0F7;font-size:.875rem;font-weight:600;margin:0 0 .25rem;">Ce site utilise des cookies</p>
      <p style="color:#9B99AA;font-size:.75rem;line-height:1.5;margin:0;">
        Cookies essentiels et mesures d'audience anonymisées uniquement. Aucun cookie publicitaire.
        <a href="/confidentialite" style="color:#7C3AED;">En savoir plus</a>
      </p>
    </div>
    <div style="display:flex;gap:.75rem;flex-shrink:0;">
      <button id="cookie-refuse" style="color:#9B99AA;font-size:.75rem;font-weight:500;padding:.5rem 1rem;border-radius:.5rem;border:1px solid rgba(255,255,255,0.15);background:transparent;cursor:pointer;">
        Refuser
      </button>
      <button id="cookie-accept" style="background:#7C3AED;color:#fff;font-size:.75rem;font-weight:500;padding:.5rem 1rem;border-radius:.5rem;border:none;cursor:pointer;">
        Accepter
      </button>
    </div>
  </div>
</div>

<script>
  (function() {
    const banner = document.getElementById('cookie-banner');
    if (!banner) return;
    if (!localStorage.getItem('cookie-consent')) {
      // Délai court pour éviter le flash au chargement
      setTimeout(() => { banner.style.opacity = '1'; }, 600);
    }
    document.getElementById('cookie-accept').onclick = function() {
      localStorage.setItem('cookie-consent', 'accepted');
      banner.style.opacity = '0';
      setTimeout(() => banner.remove(), 300);
    };
    document.getElementById('cookie-refuse').onclick = function() {
      localStorage.setItem('cookie-consent', 'refused');
      banner.style.opacity = '0';
      setTimeout(() => banner.remove(), 300);
    };
  })();
</script>
