<Layout title="Mentions légales — Gigarun" description="Mentions légales de Gigarun SARL, DSI externalisé à La Réunion.">
<section class="bg-[#07001C] pt-32 pb-20">
  <div class="max-w-3xl mx-auto px-6">
    <h1 class="font-syne font-extrabold text-[#F1F0F7] mb-8" style="font-size:clamp(28px,4vw,48px);">Mentions légales</h1>
    <div class="prose-gigarun">
      <h2>Éditeur du site</h2>
      <p><strong>GIGARUN SARL</strong><br/>Capital social : 57 500 €<br/>Siège social : 7 rue du Temple, 97410 Saint-Pierre, La Réunion<br/>SIRET : 504 015 181 00044<br/>RCS Saint-Pierre : 504 015 181</p>
      <h2>Contact</h2>
      <p>Téléphone : <a href="tel:+262692311191">0692 311 191</a><br/>Email : <a href="mailto:contact@gigarun.net">contact@gigarun.net</a></p>
      <h2>Directeur de la publication</h2>
      <p>Thomas Cauchois</p>
      <h2>Hébergement</h2>
      <p><strong>OVH SAS</strong><br/>2 rue Kellermann<br/>59100 Roubaix, France</p>
