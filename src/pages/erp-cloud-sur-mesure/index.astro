---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="ERP Cloud sur mesure à La Réunion — Gigarun" description="Offre ERP Cloud sur mesure pour PME réunionnaises : Dolibarr hébergé, du standard 10 postes au cluster multi-sociétés. Estimez votre abonnement en ligne. Dès 60 €/mois HT.">
<section class="bg-[#07001C] pt-32 pb-16">
  <div class="max-w-5xl mx-auto px-6">
    <a href="/solutions" class="text-[#9B99AA] hover:text-[#F1F0F7] text-sm">← Nos solutions</a>
    <h1 class="font-syne font-extrabold text-[#F1F0F7] mt-4 mb-5" style="font-size:clamp(32px,5vw,56px);line-height:1.1;">Offre ERP Cloud sur mesure</h1>
    <p class="text-[#9B99AA] text-lg max-w-2xl mb-8">Un ERP hébergé, dimensionné à votre activité : du standard 10 utilisateurs au cluster haute disponibilité multi-sociétés.</p>
    <div class="flex flex-wrap gap-3">
      <a href="/contact" class="bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-medium px-6 py-3 rounded-full transition-colors">Estimer mon ERP cloud</a>
      <a href="tel:+262692311191" class="border border-[rgba(255,255,255,0.2)] text-[#F1F0F7] hover:border-white font-medium px-6 py-3 rounded-full transition-colors">0692 31 11 91</a>
    </div>
  </div>
</section>
<section class="bg-[#0A0022] py-16">
  <div class="max-w-5xl mx-auto px-6 grid md:grid-cols-2 gap-6">
    <div class="bg-[#0D0028] border border-[rgba(124,58,237,0.15)] rounded-xl p-6">
      <h2 class="font-syne font-bold text-[#F1F0F7] mb-3">Nos offres</h2>
      <ul class="text-[#9B99AA] text-sm space-y-2">
        <li>Offres 10, 25 et 50 utilisateurs</li>
        <li>Versions standard, avancée, multi-sociétés</li>
        <li>Cluster système haute disponibilité</li>
        <li>Estimation en ligne immédiate</li>
      </ul>
    </div>
    <div class="bg-[#0D0028] border border-[rgba(124,58,237,0.15)] rounded-xl p-6">
      <h2 class="font-syne font-bold text-[#F1F0F7] mb-3">Inclus</h2>
      <ul class="text-[#9B99AA] text-sm space-y-2">
        <li>Hébergement local et sauvegarde</li>
        <li>Mises à jour et supervision</li>
        <li>Support et formation</li>
        <li>Évolutif selon votre croissance</li>
      </ul>
    </div>
  </div>
</section>
<section class="bg-[#07001C] py-12">
  <div class="max-w-5xl mx-auto px-6">
    <p class="text-[#9B99AA] text-sm mb-3">À voir aussi :</p>
    <div class="flex flex-wrap gap-4 text-sm">
        <a href="/devis/erp" class="text-[#7C3AED] hover:underline">Estimer mon ERP</a>
        <a href="/dolibarr" class="text-[#7C3AED] hover:underline">Dolibarr</a>
        <a href="/collaboration-erp-crm" class="text-[#7C3AED] hover:underline">ERP &amp; CRM</a>
    </div>
  </div>
</section>
</Layout>
