<Layout title="Guide VPN &amp; Acc&egrave;s Distant | T&eacute;l&eacute;travail s&eacute;curis&eacute; — Gigarun La Réunion" description="Guide VPN et acc&egrave;s distant pour le t&eacute;l&eacute;travail : connexion s&eacute;curis&eacute;e, configuration, bonnes pratiques et d&eacute;pannage pour travailler &agrave">
<div class="bg-[#07001C] pt-28 pb-4">
  <div class="max-w-4xl mx-auto px-6">
    <div class="flex items-center gap-3 mb-3">
      <a href="/blog" class="text-[#9B99AA] hover:text-[#7C3AED] text-sm transition-colors">← Blog &amp; Guides</a>
    </div>
    <div class="flex items-center gap-2 mb-2">
