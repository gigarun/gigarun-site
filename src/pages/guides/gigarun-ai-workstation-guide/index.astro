      <tbody>
        <tr><td>Simplicité de démarrage</td><td><span class="score-high">✓✓ Excellent</span></td><td><span class="score-mid">∼ Moyen</span></td><td><span class="score-high">✓ Bon</span></td></tr>
        <tr><td>Performances GPU Ollama</td><td><span class="score-high">✓✓ Natives</span></td><td><span class="score-mid">∼ -5 à -10%</span></td><td><span class="score-low">✗ -20 à -40%</span></td></tr>
        <tr><td>Isolation services clients</td><td><span class="score-low">✗ Faible</span></td><td><span class="score-high">✓✓ Forte</span></td><td><span class="score-low">✗ Faible</span></td></tr>
        <tr><td>Snapshots infra</td><td><span class="score-mid">∼ Manuel</span></td><td><span class="score-high">✓✓ Natifs</span></td><td><span class="score-low">✗ Limités</span></td></tr>
        <tr><td>Stack Docker/Linux</td><td><span class="score-high">✓✓ Native</span></td><td><span class="score-high">✓✓ Native (VM)</span></td><td><span class="score-mid">∼ WSL2</span></td></tr>
