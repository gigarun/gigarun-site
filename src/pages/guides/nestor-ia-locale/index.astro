                <tbody>
                    <tr><td><code>qwen2.5:14b</code></td><td>Agents m&eacute;tier (g&eacute;n&eacute;raliste, fran&ccedil;ais)</td><td>~9 Go</td></tr>
                    <tr><td><code>qwen3:32b</code></td><td>Raisonnement complexe, analyse (Phase 3)</td><td>~20 Go</td></tr>
