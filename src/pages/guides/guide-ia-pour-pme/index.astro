        .footer-section h4{color:#3498db;margin-bottom:15px;font-size:1.1em;border-bottom:2px solid #3498db;padding-bottom:8px}
        .footer-section ul{list-style:none;padding:0}
        .footer-section li{padding:5px 0;border-bottom:1px dotted rgba(255,255,255,0.2)}
        .footer-section a{color:#bdc3c7;text-decoration:none;transition:color 0.3s}
        .footer-section a:hover{color:#3498db}
        .footer-bottom{border-top:1px solid rgba(255,255,255,0.2);padding-top:20px;text-align:center;color:#bdc3c7}
        .footer-logo{display:flex;align-items:center;gap:10px;margin-bottom:15px}
        .back-home{display:inline-flex;align-items:center;gap:8px;padding:10px 20px;background:#7c3aed;color:white;text-decoration:none;border-radius:25px;font-weight:600;font-size:0.9em;transition:transform 0.2s,box-shadow 0.2s}
        .back-home:hover{transform:translateY(-2px);box-shadow:0 4px 12px rgba(124,58,237,0.4)}
        .back-bar{max-width:1200px;margin:0 auto;padding:20px 20px 0}
        #scrollTop{position:fixed;bottom:30px;right:30px;width:48px;height:48px;border-radius:50%;background:linear-gradient(135deg,#7c3aed,#a855f7);color:white;border:none;font-size:1.4em;cursor:pointer;box-shadow:0 4px 14px rgba(0,0,0,0.25);opacity:0;visibility:hidden;transition:opacity 0.3s,visibility 0.3s,transform 0.2s;z-index:999;display:flex;align-items:center;justify-content:center}
        #scrollTop.visible{opacity:1;visibility:visible}
        #scrollTop:hover{transform:translateY(-3px);box-shadow:0 6px 20px rgba(0,0,0,0.3)}
        .btn{display:inline-block;padding:12px 30px;background:linear-gradient(135deg,#7c3aed,#a855f7);color:white;text-decoration:none;border-radius:25px;font-weight:bold;margin-top:20px;transition:transform 0.3s,box-shadow 0.3s}
        .btn:hover{transform:translateY(-3px);box-shadow:0 5px 20px rgba(124,58,237,0.4)}
        @media(max-width:600px){.header h1{font-size:1.6em}.content{padding:20px}.header-container,.contact-header,.footer-content{flex-direction:column;gap:10px}.use-case .before-after{grid-template-columns:1fr}}
        @media print{body{background:white;padding:0}.container{box-shadow:none}.back-bar,#scrollTop{display:none}.main-header,.main-footer{break-inside:avoid}}
    
/* Corrections d'intégration */
#guide-wrapper body { background: none !important; padding: 0 !important; }
