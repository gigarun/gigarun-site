        #scrollTop:hover{transform:translateY(-3px);box-shadow:0 6px 20px rgba(0,0,0,0.3)}
        .btn{display:inline-block;padding:12px 30px;background:linear-gradient(135deg,#198754,#20c997);color:white;text-decoration:none;border-radius:25px;font-weight:bold;margin-top:20px;transition:transform 0.3s,box-shadow 0.3s}
        .btn:hover{transform:translateY(-3px);box-shadow:0 5px 20px rgba(25,135,84,0.4)}
        @media(max-width:600px){.header h1{font-size:1.6em}.content{padding:20px}.header-container,.contact-header,.footer-content{flex-direction:column;gap:10px}}
