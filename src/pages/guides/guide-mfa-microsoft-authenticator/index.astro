        .comparison-table tbody tr:nth-child(even){background:#f9f9f9}
        .comparison-table tbody tr:hover{background:#e8f5e9}
        .good{color:#198754;font-weight:bold}
        .bad{color:#dc3545;font-weight:bold}
        .kpi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:20px;margin:30px 0}
        .kpi-box{background:linear-gradient(135deg,#198754,#20c997);color:white;border-radius:10px;padding:24px;text-align:center}
        .kpi-box .value{font-size:2em;font-weight:700;display:block;margin-bottom:6px}
        .kpi-box .label{font-size:0.9em;opacity:0.85}
        .troubleshooting{background:#fff9e6;border-left:5px solid #ffc107;padding:20px;margin:20px 0;border-radius:0 10px 10px 0}
        .troubleshooting h4{color:#856404;margin-bottom:10px}
        code{background:#e9ecef;padding:2px 6px;border-radius:3px;font-family:'Courier New',monospace;color:#198754}
        .main-footer{background:linear-gradient(135deg,#2c3e50,#34495e);color:white;padding:40px 0 20px;margin-top:20px}
        .footer-container{max-width:1200px;margin:0 auto;padding:0 20px}
