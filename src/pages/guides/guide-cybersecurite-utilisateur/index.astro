        .btn{display:inline-block;padding:12px 30px;background:linear-gradient(135deg,#dc3545,#6f1520);color:white;text-decoration:none;border-radius:25px;font-weight:bold;margin-top:20px;transition:transform 0.3s,box-shadow 0.3s}
