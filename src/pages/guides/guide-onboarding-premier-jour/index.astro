        .back-home:hover{transform:translateY(-2px);box-shadow:0 4px 12px rgba(8,145,178,0.4)}
        .back-bar{max-width:1200px;margin:0 auto;padding:20px 20px 0}
        #scrollTop{position:fixed;bottom:30px;right:30px;width:48px;height:48px;border-radius:50%;background:linear-gradient(135deg,#0891b2,#06b6d4);color:white;border:none;font-size:1.4em;cursor:pointer;box-shadow:0 4px 14px rgba(0,0,0,0.25);opacity:0;visibility:hidden;transition:opacity 0.3s,visibility 0.3s,transform 0.2s;z-index:999;display:flex;align-items:center;justify-content:center}
        #scrollTop.visible{opacity:1;visibility:visible}
        #scrollTop:hover{transform:translateY(-3px);box-shadow:0 6px 20px rgba(0,0,0,0.3)}
        .btn{display:inline-block;padding:12px 30px;background:linear-gradient(135deg,#0891b2,#06b6d4);color:white;text-decoration:none;border-radius:25px;font-weight:bold;margin-top:20px;transition:transform 0.3s,box-shadow 0.3s}
        .btn:hover{transform:translateY(-3px);box-shadow:0 5px 20px rgba(8,145,178,0.4)}
        @media(max-width:600px){.header h1{font-size:1.6em}.content{padding:20px}.header-container,.contact-header,.footer-content{flex-direction:column;gap:10px}.timeline::before{left:20px}.timeline-item{padding-left:55px}}
        @media print{body{background:white;padding:0}.container{box-shadow:none}.back-bar,#scrollTop{display:none}.main-header,.main-footer{break-inside:avoid}}
    
