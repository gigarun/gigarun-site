---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Écrans interactifs & affichage dynamique à La Réunion — Gigarun" description="Écrans tactiles interactifs et affichage dynamique pour entreprises et commerces réunionnais : accueil, salles de réunion, vitrines, gestion de contenu centralisée.">
<section class="bg-[#07001C] pt-32 pb-16">
  <div class="max-w-5xl mx-auto px-6">
    <a href="/solutions" class="text-[#9B99AA] hover:text-[#F1F0F7] text-sm">← Nos solutions</a>
    <h1 class="font-syne font-extrabold text-[#F1F0F7] mt-4 mb-5" style="font-size:clamp(32px,5vw,56px);line-height:1.1;">Écrans interactifs &amp; affichage dynamique</h1>
    <p class="text-[#9B99AA] text-lg max-w-2xl mb-8">Captez l'attention et fluidifiez la communication : écrans tactiles pour vos équipes et affichage dynamique pour vos clients.</p>
    <div class="flex flex-wrap gap-3">
      <a href="/contact" class="bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-medium px-6 py-3 rounded-full transition-colors">Demander un conseil</a>
      <a href="tel:+262692311191" class="border border-[rgba(255,255,255,0.2)] text-[#F1F0F7] hover:border-white font-medium px-6 py-3 rounded-full transition-colors">0692 31 11 91</a>
    </div>
  </div>
</section>
<section class="bg-[#0A0022] py-16">
  <div class="max-w-5xl mx-auto px-6 grid md:grid-cols-2 gap-6">
    <div class="bg-[#0D0028] border border-[rgba(124,58,237,0.15)] rounded-xl p-6">
      <h2 class="font-syne font-bold text-[#F1F0F7] mb-3">Nos équipements</h2>
      <ul class="text-[#9B99AA] text-sm space-y-2">
        <li>Écrans tactiles interactifs (salles, accueil)</li>
        <li>Totems et bornes pour halls et vitrines</li>
        <li>Affichage dynamique (menus, promotions, infos)</li>
        <li>Solutions pour commerces, écoles, collectivités</li>
      </ul>
    </div>
    <div class="bg-[#0D0028] border border-[rgba(124,58,237,0.15)] rounded-xl p-6">
      <h2 class="font-syne font-bold text-[#F1F0F7] mb-3">Ce qu'on gère pour vous</h2>
      <ul class="text-[#9B99AA] text-sm space-y-2">
        <li>Conseil et choix du matériel adapté</li>
        <li>Installation et fixation</li>
        <li>Gestion de contenu à distance</li>
        <li>Maintenance et support</li>
      </ul>
    </div>
  </div>
</section>
<section class="bg-[#07001C] py-12">
  <div class="max-w-5xl mx-auto px-6">
    <p class="text-[#9B99AA] text-sm mb-3">À voir aussi :</p>
    <div class="flex flex-wrap gap-4 text-sm">
        <a href="/visioconference" class="text-[#7C3AED] hover:underline">Visioconférence</a>
        <a href="/creation-site" class="text-[#7C3AED] hover:underline">Création de site web</a>
        <a href="/contact" class="text-[#7C3AED] hover:underline">Nous contacter</a>
    </div>
  </div>
</section>
</Layout>
