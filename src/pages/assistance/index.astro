---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Assistance & support informatique (helpdesk N1-N2-N3) — Gigarun La Réunion" description="Assistance et support informatique pour entreprises réunionnaises : helpdesk réactif, dépannage à distance et sur site, niveaux N1 à N3. Réponse rapide, interlocuteur unique.">
<section class="bg-[#07001C] pt-32 pb-16">
  <div class="max-w-5xl mx-auto px-6">
    <a href="/services" class="text-[#9B99AA] hover:text-[#F1F0F7] text-sm">← Nos services</a>
    <h1 class="font-syne font-extrabold text-[#F1F0F7] mt-4 mb-5" style="font-size:clamp(32px,5vw,56px);line-height:1.1;">Assistance &amp; support informatique</h1>
    <p class="text-[#9B99AA] text-lg max-w-2xl mb-8">Un helpdesk réactif pour vos utilisateurs : on résout vite, à distance ou sur site, avec un vrai interlocuteur qui connaît votre environnement.</p>
    <div class="flex flex-wrap gap-3">
      <a href="/contact" class="bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-medium px-6 py-3 rounded-full transition-colors">Demander de l'aide</a>
      <a href="tel:+262692311191" class="border border-[rgba(255,255,255,0.2)] text-[#F1F0F7] hover:border-white font-medium px-6 py-3 rounded-full transition-colors">0692 31 11 91</a>
    </div>
  </div>
</section>
<section class="bg-[#0A0022] py-16">
  <div class="max-w-5xl mx-auto px-6 grid md:grid-cols-2 gap-6">
    <div class="bg-[#0D0028] border border-[rgba(124,58,237,0.15)] rounded-xl p-6">
      <h2 class="font-syne font-bold text-[#F1F0F7] mb-3">Notre support</h2>
      <ul class="text-[#9B99AA] text-sm space-y-2">
        <li>Helpdesk multi-canal (téléphone, email, ticket)</li>
        <li>Dépannage à distance illimité</li>
        <li>Intervention sur site dans le Sud</li>
        <li>Niveaux N1, N2 et N3</li>
      </ul>
    </div>
    <div class="bg-[#0D0028] border border-[rgba(124,58,237,0.15)] rounded-xl p-6">
      <h2 class="font-syne font-bold text-[#F1F0F7] mb-3">Bénéfices</h2>
      <ul class="text-[#9B99AA] text-sm space-y-2">
        <li>Réponse sous 24 h (4 h pour les clients sous contrat)</li>
        <li>Interlocuteur unique, pas de hotline anonyme</li>
        <li>Suivi transparent via tickets</li>
        <li>Inclus dans nos contrats d'infogérance</li>
      </ul>
    </div>
  </div>
</section>
<section class="bg-[#07001C] py-12">
  <div class="max-w-5xl mx-auto px-6">
    <p class="text-[#9B99AA] text-sm mb-3">À voir aussi :</p>
    <div class="flex flex-wrap gap-4 text-sm">
        <a href="/infogerance-contrats" class="text-[#7C3AED] hover:underline">Niveaux de service</a>
        <a href="/maintenance-tpe" class="text-[#7C3AED] hover:underline">Maintenance TPE</a>
        <a href="/contact" class="text-[#7C3AED] hover:underline">Nous contacter</a>
    </div>
  </div>
</section>
</Layout>
