---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Vidéosurveillance & contrôle d'accès à La Réunion — Gigarun" description="Vidéosurveillance et contrôle d'accès pour entreprises et commerces réunionnais : caméras IP, enregistrement sécurisé, badges, supervision à distance, conformité RGPD.">
<section class="bg-[#07001C] pt-32 pb-16">
  <div class="max-w-5xl mx-auto px-6">
    <a href="/securite" class="text-[#9B99AA] hover:text-[#F1F0F7] text-sm">← Cybersécurité</a>
    <h1 class="font-syne font-extrabold text-[#F1F0F7] mt-4 mb-5" style="font-size:clamp(32px,5vw,56px);line-height:1.1;">Vidéosurveillance &amp; contrôle d'accès</h1>
    <p class="text-[#9B99AA] text-lg max-w-2xl mb-8">Protégez vos locaux et vos équipes : caméras IP, enregistrement sécurisé et contrôle des accès, le tout supervisé et conforme au RGPD.</p>
    <div class="flex flex-wrap gap-3">
      <a href="/contact" class="bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-medium px-6 py-3 rounded-full transition-colors">Sécuriser mes locaux</a>
      <a href="tel:+262692311191" class="border border-[rgba(255,255,255,0.2)] text-[#F1F0F7] hover:border-white font-medium px-6 py-3 rounded-full transition-colors">0692 31 11 91</a>
    </div>
  </div>
</section>
<section class="bg-[#0A0022] py-16">
  <div class="max-w-5xl mx-auto px-6 grid md:grid-cols-2 gap-6">
    <div class="bg-[#0D0028] border border-[rgba(124,58,237,0.15)] rounded-xl p-6">
      <h2 class="font-syne font-bold text-[#F1F0F7] mb-3">Nos solutions</h2>
      <ul class="text-[#9B99AA] text-sm space-y-2">
        <li>Caméras IP HD, intérieur et extérieur</li>
        <li>Enregistreurs (NVR) sécurisés et sauvegardés</li>
        <li>Contrôle d'accès : badges, codes, biométrie</li>
        <li>Visualisation à distance sur mobile et PC</li>
      </ul>
    </div>
    <div class="bg-[#0D0028] border border-[rgba(124,58,237,0.15)] rounded-xl p-6">
      <h2 class="font-syne font-bold text-[#F1F0F7] mb-3">Pourquoi nous</h2>
      <ul class="text-[#9B99AA] text-sm space-y-2">
        <li>Installation et câblage réseau professionnels</li>
        <li>Conformité RGPD (signalétique, durée de conservation)</li>
        <li>Intégration à votre réseau et à vos sauvegardes</li>
        <li>Maintenance et supervision incluses</li>
      </ul>
    </div>
  </div>
</section>
<section class="bg-[#07001C] py-12">
  <div class="max-w-5xl mx-auto px-6">
    <p class="text-[#9B99AA] text-sm mb-3">À voir aussi :</p>
    <div class="flex flex-wrap gap-4 text-sm">
        <a href="/securite" class="text-[#7C3AED] hover:underline">Cybersécurité</a>
        <a href="/reseau" class="text-[#7C3AED] hover:underline">Réseau</a>
        <a href="/contact" class="text-[#7C3AED] hover:underline">Nous contacter</a>
    </div>
  </div>
</section>
</Layout>
