---
import Layout from '../layouts/Layout.astro';

const STRAPI = 'http://172.20.3.3:1337';
const STRAPI_TOKEN = '12d2cbd09c825a72ef91017966c6a4420e7634afbb64d6da13dd5ef91c2ccbaf8ac3be45a412a1b5a0963485d7259d020333aaf9a40adfd9e143212097714e626d58abe23f495ffb00176bf22b9872b500ca770544da3ea4d5222803d9c747074088a99690ec25b7fe82fb44d8240c5dcc1b67ddbca2a50284dcba2af3afc162';
const headers = { 'Authorization': `Bearer ${STRAPI_TOKEN}` };

const [servicesRes, tarifsRes, temoignagesRes] = await Promise.all([
  fetch(`${STRAPI}/api/services?sort=ordre&pagination[limit]=100`, { headers }),
  fetch(`${STRAPI}/api/tarifs?sort=ordre&pagination[limit]=100`, { headers }),
  fetch(`${STRAPI}/api/temoignages?pagination[limit]=100`, { headers }),
]);

const services = (await servicesRes.json()).data ?? [];
const tarifs = (await tarifsRes.json()).data ?? [];
const temoignages = (await temoignagesRes.json()).data ?? [];

const hero = {
  badge: 'La Réunion · DSI Externalisé',
  titre_ligne1: 'Votre informatique,',
  titre_ligne2: 'nos mains expertes',
  sous_titre: 'Infogérance, ERP Dolibarr, cybersécurité — Gigarun accompagne les PME réunionnaises depuis 15 ans.',
  cta_principal: 'Diagnostic gratuit',
  cta_secondaire: 'Voir nos services',
  stat1_chiffre: '15+', stat1_label: "Années d'expérience",
  stat2_chiffre: '100+', stat2_label: 'Clients actifs',
  stat3_chiffre: '4h', stat3_label: 'Délai intervention',
  stat4_chiffre: '5★', stat4_label: 'Satisfaction client',
};
const contact = {
  telephone: '0692 31 11 91',
  email: 'contact@gigarun.net',
  adresse: 'Saint-Pierre, La Réunion',
};
---
<Layout>

<!-- HERO -->
<section class="relative flex items-center justify-center overflow-hidden bg-[#07001C]" style="min-height:80vh; max-height:80vh;">
  <div class="absolute pointer-events-none" style="bottom:-60px; left:50%; transform:translateX(-50%); width:700px; height:400px; background:rgba(124,58,237,0.18); border-radius:50%; filter:blur(120px);"></div>
  <div class="absolute pointer-events-none" style="bottom:-40px; right:-60px; width:400px; height:300px; background:rgba(192,38,211,0.15); border-radius:50%; filter:blur(100px);"></div>

  <div class="relative max-w-4xl mx-auto px-6 pt-28 pb-16 w-full flex flex-col items-center text-center">
    <div class="inline-flex items-center gap-2 bg-[#110833] border border-[rgba(124,58,237,0.35)] px-4 py-1.5 mb-8" style="border-radius:9999px;">
      <span class="w-2 h-2 bg-[#7C3AED] pulse-dot" style="border-radius:50%;"></span>
      <span class="text-[#9B99AA] text-sm font-medium tracking-wide">{hero?.badge ?? 'La Réunion · DSI Externalisé'}</span>
    </div>

    <h1 class="font-syne font-extrabold leading-[1.05] tracking-tight text-[#F1F0F7] mb-5" style="font-size:clamp(48px,6.5vw,80px);">
      {hero?.titre_ligne1 ?? 'Votre informatique,'}<br/>
      <span class="text-transparent bg-clip-text" style="background-image:linear-gradient(135deg,#7C3AED,#06B6D4);">{hero?.titre_ligne2 ?? 'nos mains expertes'}</span>
    </h1>

    <p class="text-[#9B99AA] text-lg leading-relaxed max-w-xl mb-10">
      {hero?.sous_titre ?? "Infogérance, ERP Dolibarr, cybersécurité — un interlocuteur unique pour votre PME réunionnaise."}
    </p>

    <div class="flex flex-wrap gap-3 justify-center mb-14">
      <a href="#contact" class="inline-flex items-center gap-2 bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-medium px-6 py-3 btn-hover-lift" style="border-radius:9999px;">
        {hero?.cta_principal ?? 'Diagnostic gratuit'}
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
      <a href="#services" class="inline-flex items-center gap-2 border border-[rgba(255,255,255,0.25)] text-[#F1F0F7] hover:border-white hover:bg-[rgba(255,255,255,0.05)] font-medium px-6 py-3 btn-hover-lift" style="border-radius:9999px;">
        {hero?.cta_secondaire ?? 'Voir nos services'}
      </a>
    </div>

    <div class="flex flex-wrap items-center justify-center gap-6 md:gap-10">
      <div class="flex flex-col items-center">
        <span class="font-syne font-bold text-[#F1F0F7]" style="font-size:clamp(28px,4vw,42px);">{hero?.stat1_chiffre ?? '15+'}</span>
        <span class="text-[#9B99AA] text-sm mt-1">{hero?.stat1_label ?? "Années d'expérience"}</span>
      </div>
      <div class="w-px h-10 bg-[rgba(124,58,237,0.3)] hidden sm:block"></div>
      <div class="flex flex-col items-center">
        <span class="font-syne font-bold text-[#F1F0F7]" style="font-size:clamp(28px,4vw,42px);">{hero?.stat2_chiffre ?? '100+'}</span>
        <span class="text-[#9B99AA] text-sm mt-1">{hero?.stat2_label ?? 'Clients actifs'}</span>
      </div>
      <div class="w-px h-10 bg-[rgba(124,58,237,0.3)] hidden sm:block"></div>
      <div class="flex flex-col items-center">
        <span class="font-syne font-bold text-[#F1F0F7]" style="font-size:clamp(28px,4vw,42px);">{hero?.stat3_chiffre ?? '4h'}</span>
        <span class="text-[#9B99AA] text-sm mt-1">{hero?.stat3_label ?? 'Délai intervention'}</span>
      </div>
      <div class="w-px h-10 bg-[rgba(124,58,237,0.3)] hidden sm:block"></div>
      <div class="flex flex-col items-center">
        <span class="font-syne font-bold text-[#F1F0F7]" style="font-size:clamp(28px,4vw,42px);">{hero?.stat4_chiffre ?? '5★'}</span>
        <span class="text-[#9B99AA] text-sm mt-1">{hero?.stat4_label ?? 'Satisfaction client'}</span>
      </div>
    </div>
  </div>
</section>

<!-- SERVICES -->
<section id="services" class="bg-[#07001C] py-20">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 bg-[#110833] border border-[rgba(124,58,237,0.3)] text-[#7C3AED] text-[12px] font-medium tracking-widest uppercase px-4 py-1.5 mb-5" style="border-radius:9999px;">NOS SERVICES</div>
      <h2 class="font-syne font-bold text-[#F1F0F7]" style="font-size:clamp(28px,3vw,42px);">Ce qu'on fait pour vous</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map(s => (
        <div class="service-card bg-[#0D0028] border border-[rgba(124,58,237,0.15)] rounded-xl p-6">
          <h3 class="text-base font-semibold text-white mb-2">{s.titre}</h3>
          <p class="text-[#9B99AA] text-sm leading-relaxed">{s.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- POURQUOI GIGARUN -->
<section class="bg-[#0A0022] py-20">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <div>
        <p class="font-syne font-extrabold leading-[0.9] tracking-tight mb-5" style="font-size:clamp(52px,6.5vw,80px); background-image:linear-gradient(135deg,#7C3AED,#06B6D4); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; color:transparent;">
          15 ans<br/>d'ancrage<br/>réunionnais
        </p>
        <p class="text-[#9B99AA] text-base leading-relaxed">Votre IT local, pas un numéro de ticket.</p>
      </div>
      <div class="flex flex-col gap-6">
        <div class="flex items-start gap-4">
          <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="#06B6D4" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          <div><p class="text-white font-semibold text-sm mb-1">Un interlocuteur unique</p><p class="text-[#9B99AA] text-sm">Un seul contact pour tout votre système informatique.</p></div>
        </div>
        <div class="flex items-start gap-4">
          <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="#06B6D4" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          <div><p class="text-white font-semibold text-sm mb-1">Présence physique</p><p class="text-[#9B99AA] text-sm">Intervention sur site à Saint-Pierre sous 4 heures.</p></div>
        </div>
        <div class="flex items-start gap-4">
          <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="#06B6D4" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          <div><p class="text-white font-semibold text-sm mb-1">Expert Dolibarr</p><p class="text-[#9B99AA] text-sm">Seul intégrateur ERP open source spécialisé de l'île.</p></div>
        </div>
        <div class="flex items-start gap-4">
          <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="#06B6D4" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          <div><p class="text-white font-semibold text-sm mb-1">Ancrage local</p><p class="text-[#9B99AA] text-sm">15 ans aux côtés des entreprises réunionnaises.</p></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- TARIFS -->
<section id="tarifs" class="bg-[#07001C] py-20">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 bg-[#110833] border border-[rgba(124,58,237,0.3)] text-[#7C3AED] text-[12px] font-medium tracking-widest uppercase px-4 py-1.5 mb-5" style="border-radius:9999px;">TARIFS</div>
      <h2 class="font-syne font-bold text-[#F1F0F7]" style="font-size:clamp(28px,3vw,42px);">Forfaits mensuels</h2>
      <p class="text-[#9B99AA] text-sm mt-2">Sans engagement · Premier mois offert</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {tarifs.map(t => (
        <div class={"rounded-2xl p-8 flex flex-col relative " + (t.recommande ? "bg-[#1A0A3E] border-2 border-[#7C3AED]" : "bg-[#0D0028] border border-[rgba(124,58,237,0.2)]")}>
          {t.recommande && <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-[#7C3AED] text-white text-xs font-medium px-4 py-1.5" style="border-radius:9999px;">Recommandé</div>}
          <p class="text-[#9B99AA] text-sm font-medium mb-3">{t.nom}</p>
          <div class="mb-1"><span class="font-syne font-bold text-[#F1F0F7]" style="font-size:48px;">{t.prix}</span></div>
          <p class="text-[#9B99AA] text-xs mb-8">{t.sous_titre_prix}</p>
          <ul class="flex flex-col gap-y-3 mb-8 flex-1">
            {t.features.map((f: string) => (
              <li class="flex items-center gap-2 text-sm text-[#9B99AA]">
                <span class={t.recommande ? "text-[#06B6D4] font-bold" : "text-[#7C3AED] font-bold"}>✓</span> {f}
              </li>
            ))}
          </ul>
          <a href="#contact" class={"text-center text-sm font-medium py-2.5 rounded-lg transition-all " + (t.recommande ? "bg-[#7C3AED] hover:bg-[#6D28D9] text-white" : "border border-[rgba(124,58,237,0.4)] text-[#F1F0F7] hover:border-[#7C3AED]")}>
            {t.bouton_texte}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CTA FINAL -->
<section class="py-20 relative overflow-hidden" style="background:linear-gradient(135deg,#4C1D95,#7C3AED,#C026D3);">
  <div class="relative max-w-3xl mx-auto px-6 text-center">
    <h2 class="font-syne font-bold text-white mb-4" style="font-size:clamp(28px,3.5vw,52px);">Parlons de votre projet</h2>
    <p class="text-[rgba(255,255,255,0.8)] text-base mb-10">Diagnostic gratuit, sans engagement. Réponse sous 24h.</p>
    <a href="#contact" class="inline-flex items-center gap-2 bg-white text-[#7C3AED] font-semibold px-8 py-3 rounded-lg hover:bg-[#F1F0F7] btn-hover-lift mb-6">
      Prendre rendez-vous
    </a>
    <p class="text-[rgba(255,255,255,0.65)] text-sm">{contact?.telephone ?? '0692 31 11 91'} · {contact?.adresse ?? 'Saint-Pierre, La Réunion'}</p>
  </div>
</section>

<!-- CONTACT -->
<section id="contact" class="bg-[#07001C] py-20">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-12">
      <h2 class="font-syne font-bold text-[#F1F0F7] mb-3" style="font-size:clamp(28px,3vw,42px);">Écrivez-nous</h2>
      <p class="text-[#9B99AA] text-base">On vous répond sous 24h, sans engagement.</p>
    </div>
    <form class="max-w-lg mx-auto flex flex-col gap-4" action="https://formspree.io/f/contact" method="POST">
      <input type="text" name="name" required placeholder="Votre nom" class="w-full bg-[#110833] border border-[rgba(124,58,237,0.3)] text-[#F1F0F7] placeholder-[#4a4860] rounded-lg p-3 text-sm focus:outline-none focus:border-[#7C3AED] transition-colors"/>
      <input type="email" name="email" required placeholder="Votre email" class="w-full bg-[#110833] border border-[rgba(124,58,237,0.3)] text-[#F1F0F7] placeholder-[#4a4860] rounded-lg p-3 text-sm focus:outline-none focus:border-[#7C3AED] transition-colors"/>
      <textarea name="message" required rows="4" placeholder="Votre message…" class="w-full bg-[#110833] border border-[rgba(124,58,237,0.3)] text-[#F1F0F7] placeholder-[#4a4860] rounded-lg p-3 text-sm focus:outline-none focus:border-[#7C3AED] transition-colors resize-none"></textarea>
      <button type="submit" class="w-full bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-medium py-3 rounded-lg transition-all btn-hover-lift">Envoyer</button>
    </form>
  </div>
</section>

</Layout>

<style>
  @keyframes pulse-ring {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.4; transform: scale(1.5); }
  }
  .pulse-dot { animation: pulse-ring 2s ease-in-out infinite; display: inline-block; }
  .btn-hover-lift { transition: transform 0.18s ease, box-shadow 0.18s ease; }
  .btn-hover-lift:hover { transform: translateY(-2px); }
  .service-card { transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease; }
  .service-card:hover {
    border-color: rgba(124,58,237,0.7) !important;
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(124,58,237,0.15);
  }
</style>
