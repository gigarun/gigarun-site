---
import Layout from '../layouts/Layout.astro';
---
<Layout>

<!-- ═══════════════════════════════════════════════
     SECTION 1 — HERO
═══════════════════════════════════════════════ -->
<section class="relative flex items-center overflow-hidden bg-[#07001C]" style="min-height:85vh; max-height:85vh;">
  <!-- Grille géométrique -->
  <div class="absolute inset-0 pointer-events-none" style="background-image: linear-gradient(rgba(124,58,237,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(124,58,237,0.05) 1px, transparent 1px); background-size: 48px 48px;"></div>
  <!-- Blob violet -->
  <div class="absolute pointer-events-none" style="top:20%; left:55%; transform:translate(-50%,-50%); width:500px; height:280px; background:rgba(124,58,237,0.12); border-radius:50%; filter:blur(100px);"></div>
  <!-- Blob cyan secondaire -->
  <div class="absolute pointer-events-none" style="bottom:10%; right:5%; width:250px; height:150px; background:rgba(6,182,212,0.07); border-radius:50%; filter:blur(80px);"></div>

  <div class="relative max-w-7xl mx-auto px-6 pt-28 pb-12 w-full">
    <!-- Badge pill -->
    <div class="inline-flex items-center gap-2 bg-[#110833] border border-[rgba(124,58,237,0.35)] rounded-full px-4 py-1.5 mb-6 badge-anim">
      <span class="w-2 h-2 rounded-full bg-[#7C3AED] pulse-dot"></span>
      <span class="text-[#9B99AA] text-sm font-medium tracking-wide">DSI Externalisé · La Réunion</span>
    </div>

    <!-- H1 -->
    <h1 class="font-syne font-extrabold leading-[1.05] tracking-tight text-[#F1F0F7] mb-4 max-w-3xl" style="font-size:clamp(42px,6vw,72px);">
      Votre informatique,<br/>
      <span class="text-transparent bg-clip-text" style="background-image:linear-gradient(135deg,#7C3AED,#06B6D4);">nos mains expertes</span>
    </h1>

    <!-- Sous-titre -->
    <p class="text-[#9B99AA] leading-relaxed max-w-xl mb-8" style="font-size:clamp(15px,1.2vw,18px);">
      Infogérance, ERP Dolibarr, cybersécurité — un interlocuteur unique<br class="hidden md:block"/>pour toute la DSI de votre PME réunionnaise.
    </p>

    <!-- CTAs -->
    <div class="flex flex-wrap gap-3 mb-10">
      <a href="#contact" class="inline-flex items-center gap-2 bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-medium px-6 py-3 rounded-lg btn-hover-lift">
        Diagnostic gratuit
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
      <a href="#services" class="inline-flex items-center gap-2 border border-[rgba(124,58,237,0.4)] text-[#F1F0F7] hover:border-[#7C3AED] hover:bg-[#110833] font-medium px-6 py-3 rounded-lg btn-hover-lift">
        Nos services
      </a>
    </div>

    <!-- Stats inline -->
    <div class="flex flex-wrap items-center gap-6">
      <div class="flex items-center gap-2">
        <span class="text-[#7C3AED] font-syne font-bold text-xl">15</span>
        <span class="text-[#9B99AA] text-sm">ans d'expérience</span>
      </div>
      <div class="w-px h-5 bg-[rgba(124,58,237,0.3)]"></div>
      <div class="flex items-center gap-2">
        <span class="text-[#7C3AED] font-syne font-bold text-xl">100+</span>
        <span class="text-[#9B99AA] text-sm">clients actifs</span>
      </div>
      <div class="w-px h-5 bg-[rgba(124,58,237,0.3)]"></div>
      <div class="flex items-center gap-2">
        <span class="text-[#06B6D4] font-syne font-bold text-xl">4h</span>
        <span class="text-[#9B99AA] text-sm">intervention max</span>
      </div>
    </div>

    <!-- Scroll hint -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 opacity-40">
      <span class="text-[#9B99AA] text-xs tracking-widest uppercase">scroll</span>
      <div class="scroll-arrow"></div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════
     SECTION 2 — SERVICES
═══════════════════════════════════════════════ -->
<section id="services" class="bg-[#07001C] py-20">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-12">
      <p class="text-[#7C3AED] text-sm font-medium tracking-widest uppercase mb-2">Expertise</p>
      <h2 class="font-syne font-bold text-[#F1F0F7]" style="font-size:clamp(28px,3vw,40px);">Ce qu'on fait pour vous</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">

      <!-- Carte 1 -->
      <div class="service-card bg-[#110833] border border-[rgba(124,58,237,0.15)] rounded-xl p-6">
        <div class="w-10 h-10 rounded-lg bg-[rgba(124,58,237,0.15)] flex items-center justify-center mb-4">
          <svg width="20" height="20" fill="none" stroke="#7C3AED" stroke-width="1.8" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
        </div>
        <h3 class="font-syne font-bold text-[#F1F0F7] text-base mb-1">Infogérance IT</h3>
        <p class="text-[#9B99AA] text-sm leading-relaxed">Supervision 24/7, maintenance préventive, support utilisateurs.</p>
      </div>

      <!-- Carte 2 -->
      <div class="service-card bg-[#110833] border border-[rgba(124,58,237,0.15)] rounded-xl p-6">
        <div class="w-10 h-10 rounded-lg bg-[rgba(6,182,212,0.12)] flex items-center justify-center mb-4">
          <svg width="20" height="20" fill="none" stroke="#06B6D4" stroke-width="1.8" viewBox="0 0 24 24"><path d="M4 7h16M4 12h10M4 17h7"/><circle cx="19" cy="17" r="3"/><path d="M21 19l1.5 1.5"/></svg>
        </div>
        <h3 class="font-syne font-bold text-[#F1F0F7] text-base mb-1">ERP Dolibarr</h3>
        <p class="text-[#9B99AA] text-sm leading-relaxed">Déploiement, paramétrage, formation et maintenance de votre ERP.</p>
      </div>

      <!-- Carte 3 -->
      <div class="service-card bg-[#110833] border border-[rgba(124,58,237,0.15)] rounded-xl p-6">
        <div class="w-10 h-10 rounded-lg bg-[rgba(124,58,237,0.15)] flex items-center justify-center mb-4">
          <svg width="20" height="20" fill="none" stroke="#7C3AED" stroke-width="1.8" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3 class="font-syne font-bold text-[#F1F0F7] text-base mb-1">Cybersécurité</h3>
        <p class="text-[#9B99AA] text-sm leading-relaxed">Audit de sécurité, protection des données, conformité RGPD.</p>
      </div>

      <!-- Carte 4 -->
      <div class="service-card bg-[#110833] border border-[rgba(124,58,237,0.15)] rounded-xl p-6">
        <div class="w-10 h-10 rounded-lg bg-[rgba(6,182,212,0.12)] flex items-center justify-center mb-4">
          <svg width="20" height="20" fill="none" stroke="#06B6D4" stroke-width="1.8" viewBox="0 0 24 24"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><circle cx="12" cy="20" r="1" fill="#06B6D4"/></svg>
        </div>
        <h3 class="font-syne font-bold text-[#F1F0F7] text-base mb-1">Réseaux &amp; Infrastructure</h3>
        <p class="text-[#9B99AA] text-sm leading-relaxed">Câblage, Wi-Fi, VPN, firewall et infrastructure cloud.</p>
      </div>

      <!-- Carte 5 -->
      <div class="service-card bg-[#110833] border border-[rgba(124,58,237,0.15)] rounded-xl p-6">
        <div class="w-10 h-10 rounded-lg bg-[rgba(124,58,237,0.15)] flex items-center justify-center mb-4">
          <svg width="20" height="20" fill="none" stroke="#7C3AED" stroke-width="1.8" viewBox="0 0 24 24"><path d="M15 10l4.553-2.069A1 1 0 0 1 21 8.845v6.31a1 1 0 0 1-1.447.894L15 14"/><rect x="1" y="6" width="14" height="12" rx="2"/></svg>
        </div>
        <h3 class="font-syne font-bold text-[#F1F0F7] text-base mb-1">Vidéosurveillance</h3>
        <p class="text-[#9B99AA] text-sm leading-relaxed">Systèmes IP, stockage cloud sécurisé, accès mobile.</p>
      </div>

      <!-- Carte 6 -->
      <div class="service-card bg-[#110833] border border-[rgba(124,58,237,0.15)] rounded-xl p-6">
        <div class="w-10 h-10 rounded-lg bg-[rgba(6,182,212,0.12)] flex items-center justify-center mb-4">
          <svg width="20" height="20" fill="none" stroke="#06B6D4" stroke-width="1.8" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
        </div>
        <h3 class="font-syne font-bold text-[#F1F0F7] text-base mb-1">Astreinte &amp; Urgences</h3>
        <p class="text-[#9B99AA] text-sm leading-relaxed">Hotline dédiée, intervention sur site en moins de 4h.</p>
      </div>

    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════
     SECTION 3 — POURQUOI GIGARUN
═══════════════════════════════════════════════ -->
<section class="bg-[#110833] py-20 relative overflow-hidden">
  <div class="absolute right-0 top-0 w-96 h-full pointer-events-none" style="background:linear-gradient(90deg,transparent,rgba(124,58,237,0.04));"></div>
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">

      <!-- Gauche : grand texte -->
      <div>
        <p class="font-syne font-extrabold leading-[0.95] tracking-tight" style="font-size:clamp(52px,7vw,90px); background-image:linear-gradient(135deg,#7C3AED 0%,#06B6D4 60%,rgba(124,58,237,0.3) 100%); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; color:transparent;">
          15 ans<br/>d'ancrage<br/>réunionnais
        </p>
        <p class="text-[#9B99AA] text-sm mt-4 leading-relaxed max-w-xs">
          Fondée à Saint-Pierre, Gigarun accompagne les PME locales avec une connaissance terrain que les prestataires nationaux n'ont pas.
        </p>
      </div>

      <!-- Droite : 4 arguments -->
      <div class="space-y-5">
        <div class="flex items-start gap-4">
          <div class="w-7 h-7 rounded-full bg-[rgba(6,182,212,0.15)] flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg width="14" height="14" fill="none" stroke="#06B6D4" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          </div>
          <div>
            <p class="text-[#F1F0F7] font-medium text-sm">Interlocuteur unique</p>
            <p class="text-[#9B99AA] text-sm">Un seul contact pour tout votre SI, pas de renvoi en boucle.</p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="w-7 h-7 rounded-full bg-[rgba(6,182,212,0.15)] flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg width="14" height="14" fill="none" stroke="#06B6D4" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          </div>
          <div>
            <p class="text-[#F1F0F7] font-medium text-sm">Intervention rapide</p>
            <p class="text-[#9B99AA] text-sm">Sur site à La Réunion en moins de 4h. On connaît les routes.</p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="w-7 h-7 rounded-full bg-[rgba(6,182,212,0.15)] flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg width="14" height="14" fill="none" stroke="#06B6D4" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          </div>
          <div>
            <p class="text-[#F1F0F7] font-medium text-sm">Tarifs clairs et fixes</p>
            <p class="text-[#9B99AA] text-sm">Pas de surprise sur la facture. Forfaits mensuels tout compris.</p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="w-7 h-7 rounded-full bg-[rgba(6,182,212,0.15)] flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg width="14" height="14" fill="none" stroke="#06B6D4" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          </div>
          <div>
            <p class="text-[#F1F0F7] font-medium text-sm">Stack moderne &amp; local</p>
            <p class="text-[#9B99AA] text-sm">Open source privilégié, données hébergées à La Réunion.</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════
     SECTION 4 — TARIFS
═══════════════════════════════════════════════ -->
<section id="tarifs" class="bg-[#07001C] py-20">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-12">
      <p class="text-[#7C3AED] text-sm font-medium tracking-widest uppercase mb-2">Tarifs</p>
      <h2 class="font-syne font-bold text-[#F1F0F7]" style="font-size:clamp(28px,3vw,40px);">Forfaits mensuels</h2>
      <p class="text-[#9B99AA] text-sm mt-2">Sans engagement longue durée · Résiliable à 30 jours</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">

      <!-- Starter -->
      <div class="bg-[#110833] border border-[rgba(124,58,237,0.2)] rounded-2xl p-7 flex flex-col">
        <p class="text-[#9B99AA] text-sm font-medium mb-1">Starter</p>
        <div class="flex items-end gap-1 mb-1">
          <span class="font-syne font-bold text-[#F1F0F7] text-4xl">390</span>
          <span class="text-[#9B99AA] text-sm mb-1">€/mois</span>
        </div>
        <p class="text-[#9B99AA] text-xs mb-6">Jusqu'à 5 postes</p>
        <ul class="space-y-2.5 mb-8 flex-1">
          <li class="flex items-center gap-2 text-sm text-[#9B99AA]"><span class="text-[#7C3AED]">✓</span> Supervision &amp; alertes</li>
          <li class="flex items-center gap-2 text-sm text-[#9B99AA]"><span class="text-[#7C3AED]">✓</span> Support téléphonique</li>
          <li class="flex items-center gap-2 text-sm text-[#9B99AA]"><span class="text-[#7C3AED]">✓</span> Mises à jour sécurité</li>
          <li class="flex items-center gap-2 text-sm text-[#9B99AA]"><span class="text-[#7C3AED]">✓</span> 2h d'intervention/mois</li>
        </ul>
        <a href="#contact" class="text-center border border-[rgba(124,58,237,0.4)] text-[#F1F0F7] hover:bg-[#110833] hover:border-[#7C3AED] text-sm font-medium py-2.5 rounded-lg transition-all">
          Démarrer
        </a>
      </div>

      <!-- Business — Recommandé -->
      <div class="bg-[#110833] border-2 border-[#7C3AED] rounded-2xl p-7 flex flex-col relative shadow-xl shadow-[#7C3AED]/10">
        <div class="absolute -top-3.5 left-1/2 -translate-x-1/2 bg-[#7C3AED] text-white text-xs font-medium px-4 py-1 rounded-full">Recommandé</div>
        <p class="text-[#9B99AA] text-sm font-medium mb-1">Business</p>
        <div class="flex items-end gap-1 mb-1">
          <span class="font-syne font-bold text-[#F1F0F7] text-4xl">690</span>
          <span class="text-[#9B99AA] text-sm mb-1">€/mois</span>
        </div>
        <p class="text-[#9B99AA] text-xs mb-6">Jusqu'à 15 postes</p>
        <ul class="space-y-2.5 mb-8 flex-1">
          <li class="flex items-center gap-2 text-sm text-[#9B99AA]"><span class="text-[#06B6D4]">✓</span> Tout Starter inclus</li>
          <li class="flex items-center gap-2 text-sm text-[#9B99AA]"><span class="text-[#06B6D4]">✓</span> Astreinte 7j/7</li>
          <li class="flex items-center gap-2 text-sm text-[#9B99AA]"><span class="text-[#06B6D4]">✓</span> Sauvegarde quotidienne</li>
          <li class="flex items-center gap-2 text-sm text-[#9B99AA]"><span class="text-[#06B6D4]">✓</span> 5h d'intervention/mois</li>
          <li class="flex items-center gap-2 text-sm text-[#9B99AA]"><span class="text-[#06B6D4]">✓</span> Rapport mensuel</li>
        </ul>
        <a href="#contact" class="text-center bg-[#7C3AED] hover:bg-[#6D28D9] text-white text-sm font-medium py-2.5 rounded-lg transition-all btn-hover-lift">
          Démarrer
        </a>
      </div>

      <!-- Enterprise -->
      <div class="bg-[#110833] border border-[rgba(124,58,237,0.2)] rounded-2xl p-7 flex flex-col">
        <p class="text-[#9B99AA] text-sm font-medium mb-1">Enterprise</p>
        <div class="flex items-end gap-1 mb-1">
          <span class="font-syne font-bold text-[#F1F0F7] text-4xl">Sur</span>
        </div>
        <p class="text-[#9B99AA] text-xs mb-6">devis · +15 postes</p>
        <ul class="space-y-2.5 mb-8 flex-1">
          <li class="flex items-center gap-2 text-sm text-[#9B99AA]"><span class="text-[#7C3AED]">✓</span> Tout Business inclus</li>
          <li class="flex items-center gap-2 text-sm text-[#9B99AA]"><span class="text-[#7C3AED]">✓</span> DSI à temps partagé</li>
          <li class="flex items-center gap-2 text-sm text-[#9B99AA]"><span class="text-[#7C3AED]">✓</span> SLA personnalisé</li>
          <li class="flex items-center gap-2 text-sm text-[#9B99AA]"><span class="text-[#7C3AED]">✓</span> Audit sécurité annuel</li>
        </ul>
        <a href="#contact" class="text-center border border-[rgba(124,58,237,0.4)] text-[#F1F0F7] hover:bg-[#110833] hover:border-[#7C3AED] text-sm font-medium py-2.5 rounded-lg transition-all">
          Nous contacter
        </a>
      </div>

    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════
     SECTION 5 — CTA FINAL
═══════════════════════════════════════════════ -->
<section class="py-20 relative overflow-hidden" style="background:linear-gradient(135deg,#3B1370 0%,#1e0a4a 50%,#07001C 100%);">
  <div class="absolute inset-0 pointer-events-none" style="background-image:linear-gradient(rgba(124,58,237,0.08) 1px,transparent 1px),linear-gradient(90deg,rgba(124,58,237,0.08) 1px,transparent 1px);background-size:40px 40px;"></div>
  <div class="relative max-w-3xl mx-auto px-6 text-center">
    <h2 class="font-syne font-bold text-[#F1F0F7] mb-3" style="font-size:clamp(28px,3.5vw,48px);">Parlons de votre projet</h2>
    <p class="text-[rgba(241,240,247,0.7)] text-base mb-8">Diagnostic gratuit · Réponse sous 24h</p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="#contact" class="inline-flex items-center gap-2 bg-white text-[#07001C] font-semibold px-7 py-3 rounded-lg hover:bg-[#F1F0F7] btn-hover-lift">
        Demander un diagnostic
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
      <div class="flex items-center gap-4 text-[rgba(241,240,247,0.6)] text-sm">
        <a href="tel:+262692311191" class="hover:text-white transition-colors">0692 31 11 91</a>
        <span>·</span>
        <a href="mailto:contact@gigarun.net" class="hover:text-white transition-colors">contact@gigarun.net</a>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════
     SECTION 6 — CONTACT
═══════════════════════════════════════════════ -->
<section id="contact" class="bg-[#07001C] py-20">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16">

      <!-- Formulaire -->
      <div>
        <p class="text-[#7C3AED] text-sm font-medium tracking-widest uppercase mb-2">Contact</p>
        <h2 class="font-syne font-bold text-[#F1F0F7] mb-6" style="font-size:clamp(24px,2.5vw,36px);">Écrivez-nous</h2>
        <form class="space-y-4" action="https://formspree.io/f/contact" method="POST">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-[#9B99AA] text-xs font-medium mb-1.5 uppercase tracking-wider">Nom</label>
              <input type="text" name="name" required placeholder="Jean Dupont"
                class="w-full bg-[#110833] border border-[rgba(124,58,237,0.25)] text-[#F1F0F7] placeholder-[#4a4860] rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-[#7C3AED] transition-colors"/>
            </div>
            <div>
              <label class="block text-[#9B99AA] text-xs font-medium mb-1.5 uppercase tracking-wider">Email</label>
              <input type="email" name="email" required placeholder="vous@exemple.fr"
                class="w-full bg-[#110833] border border-[rgba(124,58,237,0.25)] text-[#F1F0F7] placeholder-[#4a4860] rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-[#7C3AED] transition-colors"/>
            </div>
          </div>
          <div>
            <label class="block text-[#9B99AA] text-xs font-medium mb-1.5 uppercase tracking-wider">Message</label>
            <textarea name="message" required rows="5" placeholder="Décrivez votre besoin…"
              class="w-full bg-[#110833] border border-[rgba(124,58,237,0.25)] text-[#F1F0F7] placeholder-[#4a4860] rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-[#7C3AED] transition-colors resize-none"></textarea>
          </div>
          <button type="submit"
