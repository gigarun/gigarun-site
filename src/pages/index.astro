---
import Layout from '../layouts/Layout.astro';
---
<Layout>

<!-- HERO -->
<section class="relative min-h-screen flex items-center overflow-hidden bg-[#07001C]">
  <div class="absolute inset-0 pointer-events-none" style="background-image: linear-gradient(rgba(124,58,237,0.06) 1px, transparent 1px), linear-gradient(90deg, rgba(124,58,237,0.06) 1px, transparent 1px); background-size: 60px 60px;"></div>
  <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[400px] bg-[#7C3AED]/10 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-6 pt-32 pb-24 w-full">
    <div class="inline-flex items-center gap-2 bg-[#110833] border border-[rgba(124,58,237,0.3)] rounded-full px-4 py-1.5 mb-8">
      <span class="w-2 h-2 rounded-full bg-[#7C3AED] animate-pulse"></span>
      <span class="text-[#9B99AA] text-sm font-medium">DSI Externalisé · La Réunion</span>
    </div>

    <h1 class="font-syne font-extrabold text-[clamp(48px,7vw,88px)] leading-[1.05] tracking-tight text-[#F1F0F7] mb-6 max-w-4xl">
      Votre informatique,<br/>
      <span class="text-transparent bg-clip-text" style="background-image: linear-gradient(135deg, #7C3AED, #06B6D4);">nos mains expertes</span>
    </h1>

    <p class="text-[#9B99AA] text-lg md:text-xl leading-relaxed max-w-2xl mb-10">
      Infogérance, ERP Dolibarr, cybersécurité — Gigarun accompagne les PME réunionnaises depuis 15 ans avec un interlocuteur unique pour tout votre système informatique.
    </p>

    <div class="flex flex-wrap gap-4 mb-16">
      <a href="#contact" class="inline-flex items-center gap-2 bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-medium px-7 py-3.5 rounded-lg transition-all hover:-translate-y-0.5 hover:shadow-lg hover:shadow-[#7C3AED]/30">
        Diagnostic gratuit
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
      <a href="#services" class="inline-flex items-center gap-2 border border-[rgba(124,58,237,0.4)] hover:border-[#7C3AED] text-[#F1F0F7] font-medium px-7 py-3.5 rounded-lg transition-all hover:-translate-y-0.5">
        Nos services
      </a>
    </div>

    <div class="flex flex-wrap gap-6 text-sm text-[#9B99AA]">
      <span class="flex items-center gap-2"><span class="text-[#7C3AED] font-bold">15 ans</span> d&apos;expérience</span>
      <span class="text-[rgba(124,58,237,0.3)]">·</span>
      <span class="flex items-center gap-2"><span class="text-[#7C3AED] font-bold">100+</span> clients</span>
      <span class="text-[rgba(124,58,237,0.3)]">·</span>
      <span class="flex items-center gap-2">Intervention <span class="text-[#7C3AED] font-bold">4h</span></span>
      <span class="text-[rgba(124,58,237,0.3)]">·</span>
      <span>La Réunion</span>
    </div>
  </div>
</section>

<!-- SERVICES -->
<section id="services" class="py-24 bg-[#06000F]">
  <div class="max-w-7xl mx-auto px-6">
    <div class="mb-14">
      <p class="text-[#7C3AED] text-sm font-medium uppercase tracking-widest mb-3">Ce qu&apos;on fait</p>
      <h2 class="font-syne font-bold text-4xl md:text-5xl text-[#F1F0F7] max-w-xl leading-tight">Tout votre IT,<br/>un seul partenaire</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">

      <div id="infogerance" class="group bg-[#110833] border border-[rgba(124,58,237,0.15)] hover:border-[rgba(124,58,237,0.4)] rounded-xl p-7 transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-[#7C3AED]/10 cursor-pointer">
        <div class="w-11 h-11 rounded-lg bg-[#7C3AED]/15 flex items-center justify-center mb-5">
          <svg class="w-5 h-5 text-[#7C3AED]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2v-4M9 21H5a2 2 0 01-2-2v-4m0 0h18"/>
          </svg>
        </div>
        <h3 class="font-syne font-bold text-lg text-[#F1F0F7] mb-2">Infogérance IT</h3>
        <p class="text-[#9B99AA] text-sm leading-relaxed mb-5">Surveillance 24/7, maintenance préventive, helpdesk. Vos postes et serveurs entre de bonnes mains.</p>
        <a href="#tarifs" class="inline-flex items-center gap-1.5 text-[#7C3AED] text-sm font-medium group-hover:gap-2.5 transition-all">
          En savoir + <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>

      <div id="dolibarr" class="group bg-[#110833] border border-[rgba(124,58,237,0.15)] hover:border-[rgba(124,58,237,0.4)] rounded-xl p-7 transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-[#7C3AED]/10 cursor-pointer">
        <div class="w-11 h-11 rounded-lg bg-[#06B6D4]/10 flex items-center justify-center mb-5">
          <svg class="w-5 h-5 text-[#06B6D4]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
          </svg>
        </div>
        <h3 class="font-syne font-bold text-lg text-[#F1F0F7] mb-2">ERP Dolibarr</h3>
        <p class="text-[#9B99AA] text-sm leading-relaxed mb-5">Intégration, formation, développement sur mesure. L&apos;ERP open source adapté à votre métier.</p>
        <a href="#contact" class="inline-flex items-center gap-1.5 text-[#06B6D4] text-sm font-medium group-hover:gap-2.5 transition-all">
          En savoir + <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>

      <div id="cybersecurite" class="group bg-[#110833] border border-[rgba(124,58,237,0.15)] hover:border-[rgba(124,58,237,0.4)] rounded-xl p-7 transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-[#7C3AED]/10 cursor-pointer">
        <div class="w-11 h-11 rounded-lg bg-[#7C3AED]/15 flex items-center justify-center mb-5">
          <svg class="w-5 h-5 text-[#7C3AED]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <h3 class="font-syne font-bold text-lg text-[#F1F0F7] mb-2">Cybersécurité</h3>
        <p class="text-[#9B99AA] text-sm leading-relaxed mb-5">Audit, antivirus managé, sauvegardes chiffrées, plan de reprise. Vos données protégées.</p>
        <a href="#contact" class="inline-flex items-center gap-1.5 text-[#7C3AED] text-sm font-medium group-hover:gap-2.5 transition-all">
          En savoir + <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>

      <div class="group bg-[#110833] border border-[rgba(124,58,237,0.15)] hover:border-[rgba(124,58,237,0.4)] rounded-xl p-7 transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-[#7C3AED]/10 cursor-pointer">
        <div class="w-11 h-11 rounded-lg bg-[#06B6D4]/10 flex items-center justify-center mb-5">
          <svg class="w-5 h-5 text-[#06B6D4]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.14 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0"/>
          </svg>
        </div>
        <h3 class="font-syne font-bold text-lg text-[#F1F0F7] mb-2">Réseaux &amp; Infrastructure</h3>
        <p class="text-[#9B99AA] text-sm leading-relaxed mb-5">Architecture réseau, VPN, Wi-Fi entreprise, VLAN. Une base solide pour votre activité.</p>
        <a href="#contact" class="inline-flex items-center gap-1.5 text-[#06B6D4] text-sm font-medium group-hover:gap-2.5 transition-all">
          En savoir + <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>

      <div class="group bg-[#110833] border border-[rgba(124,58,237,0.15)] hover:border-[rgba(124,58,237,0.4)] rounded-xl p-7 transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-[#7C3AED]/10 cursor-pointer">
        <div class="w-11 h-11 rounded-lg bg-[#7C3AED]/15 flex items-center justify-center mb-5">
          <svg class="w-5 h-5 text-[#7C3AED]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.069A1 1 0 0121 8.87v6.26a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
          </svg>
        </div>
        <h3 class="font-syne font-bold text-lg text-[#F1F0F7] mb-2">Vidéosurveillance</h3>
        <p class="text-[#9B99AA] text-sm leading-relaxed mb-5">Installation et supervision de systèmes de vidéoprotection pour vos locaux professionnels.</p>
        <a href="#contact" class="inline-flex items-center gap-1.5 text-[#7C3AED] text-sm font-medium group-hover:gap-2.5 transition-all">
          En savoir + <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>

      <div class="group bg-[#110833] border border-[rgba(124,58,237,0.15)] hover:border-[rgba(124,58,237,0.4)] rounded-xl p-7 transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-[#7C3AED]/10 cursor-pointer">
        <div class="w-11 h-11 rounded-lg bg-[#06B6D4]/10 flex items-center justify-center mb-5">
          <svg class="w-5 h-5 text-[#06B6D4]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/>
          </svg>
        </div>
        <h3 class="font-syne font-bold text-lg text-[#F1F0F7] mb-2">Cloud &amp; Hébergement</h3>
        <p class="text-[#9B99AA] text-sm leading-relaxed mb-5">Serveurs dédiés hébergés à La Réunion. Souveraineté et proximité de vos données.</p>
        <a href="#contact" class="inline-flex items-center gap-1.5 text-[#06B6D4] text-sm font-medium group-hover:gap-2.5 transition-all">
          En savoir + <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>

    </div>
  </div>
</section>

<!-- POURQUOI GIGARUN -->
<section class="py-24 bg-[#07001C] relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none" style="background-image: linear-gradient(rgba(6,182,212,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(6,182,212,0.04) 1px, transparent 1px); background-size: 80px 80px;"></div>
  <div class="relative max-w-7xl mx-auto px-6">
    <div class="mb-14">
      <p class="text-[#06B6D4] text-sm font-medium uppercase tracking-widest mb-3">Nos différences</p>
      <h2 class="font-syne font-bold text-4xl md:text-5xl text-[#F1F0F7] leading-tight">Ce que vous ne trouvez pas<br/>ailleurs à La Réunion</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

      <div class="flex gap-5 p-7 bg-[#110833] rounded-xl border border-[rgba(124,58,237,0.15)]">
        <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-[#7C3AED]/20 flex items-center justify-center">
          <svg class="w-5 h-5 text-[#7C3AED]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
        </div>
        <div>
          <h3 class="font-syne font-bold text-[#F1F0F7] mb-1.5">Interlocuteur unique</h3>
          <p class="text-[#9B99AA] text-sm leading-relaxed">Un seul contact pour tout votre IT. Pas de ticket, pas de hotline, pas de renvoi de responsabilité.</p>
        </div>
      </div>

      <div class="flex gap-5 p-7 bg-[#110833] rounded-xl border border-[rgba(124,58,237,0.15)]">
        <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-[#06B6D4]/15 flex items-center justify-center">
          <svg class="w-5 h-5 text-[#06B6D4]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <div>
          <h3 class="font-syne font-bold text-[#F1F0F7] mb-1.5">Présence physique</h3>
          <p class="text-[#9B99AA] text-sm leading-relaxed">Intervention sur site à Saint-Pierre et alentours sous 4h. Pas un prestataire métropolitain qui dépanne à distance.</p>
        </div>
      </div>

      <div class="flex gap-5 p-7 bg-[#110833] rounded-xl border border-[rgba(124,58,237,0.15)]">
        <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-[#7C3AED]/20 flex items-center justify-center">
          <svg class="w-5 h-5 text-[#7C3AED]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
          </svg>
        </div>
        <div>
          <h3 class="font-syne font-bold text-[#F1F0F7] mb-1.5">Expert Dolibarr</h3>
          <p class="text-[#9B99AA] text-sm leading-relaxed">Seul intégrateur ERP open source spécialisé de l&apos;île. Intégration, personnalisation, modules métier.</p>
        </div>
      </div>

      <div class="flex gap-5 p-7 bg-[#110833] rounded-xl border border-[rgba(124,58,237,0.15)]">
        <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-[#06B6D4]/15 flex items-center justify-center">
          <svg class="w-5 h-5 text-[#06B6D4]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div>
          <h3 class="font-syne font-bold text-[#F1F0F7] mb-1.5">15 ans de terrain</h3>
          <p class="text-[#9B99AA] text-sm leading-relaxed">Nous connaissons le tissu économique réunionnais. BTP, commerce, santé, services — on a les retours d&apos;expérience.</p>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- TARIFS -->
<section id="tarifs" class="py-24 bg-[#06000F]">
  <div class="max-w-7xl mx-auto px-6">
    <div class="mb-14 text-center">
      <p class="text-[#7C3AED] text-sm font-medium uppercase tracking-widest mb-3">Tarifs</p>
      <h2 class="font-syne font-bold text-4xl md:text-5xl text-[#F1F0F7] mb-4">Infogérance au poste</h2>
      <p class="text-[#9B99AA]">Premier mois offert · Sans engagement</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">

      <div class="bg-[#110833] border border-[rgba(124,58,237,0.2)] rounded-xl p-8">
        <h3 class="font-syne font-bold text-lg text-[#F1F0F7] mb-1">Essentiel</h3>
        <p class="text-[#9B99AA] text-sm mb-6">Pour les petites structures</p>
        <div class="mb-6">
          <span class="text-4xl font-syne font-extrabold text-[#F1F0F7]">15€</span>
          <span class="text-[#9B99AA] text-sm">/poste/mois</span>
          <p class="text-[#9B99AA] text-xs mt-1">à partir de</p>
        </div>
        <ul class="space-y-3 mb-8">
          <li class="flex items-center gap-2.5 text-sm text-[#9B99AA]">
            <svg class="w-4 h-4 text-[#7C3AED] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Surveillance postes &amp; serveurs
          </li>
          <li class="flex items-center gap-2.5 text-sm text-[#9B99AA]">
            <svg class="w-4 h-4 text-[#7C3AED] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Mises à jour automatisées
          </li>
          <li class="flex items-center gap-2.5 text-sm text-[#9B99AA]">
            <svg class="w-4 h-4 text-[#7C3AED] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Antivirus managé
          </li>
        </ul>
        <a href="#contact" class="block text-center border border-[rgba(124,58,237,0.4)] hover:border-[#7C3AED] text-[#F1F0F7] font-medium py-3 rounded-lg transition-colors text-sm">
          Demander un devis
        </a>
      </div>

      <div class="bg-[#110833] border border-[#7C3AED] rounded-xl p-8 relative">
        <div class="absolute -top-3.5 left-1/2 -translate-x-1/2 bg-[#7C3AED] text-white text-xs font-medium px-4 py-1 rounded-full">Recommandé</div>
        <h3 class="font-syne font-bold text-lg text-[#F1F0F7] mb-1">Business</h3>
        <p class="text-[#9B99AA] text-sm mb-6">Pour les PME actives</p>
        <div class="mb-6">
          <span class="text-4xl font-syne font-extrabold text-[#F1F0F7]">25€</span>
          <span class="text-[#9B99AA] text-sm">/poste/mois</span>
          <p class="text-[#9B99AA] text-xs mt-1">à partir de</p>
        </div>
        <ul class="space-y-3 mb-8">
          <li class="flex items-center gap-2.5 text-sm text-[#9B99AA]">
            <svg class="w-4 h-4 text-[#7C3AED] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Tout l&apos;offre Essentiel
          </li>
          <li class="flex items-center gap-2.5 text-sm text-[#9B99AA]">
            <svg class="w-4 h-4 text-[#7C3AED] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Helpdesk illimité
          </li>
          <li class="flex items-center gap-2.5 text-sm text-[#9B99AA]">
            <svg class="w-4 h-4 text-[#7C3AED] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Sauvegardes externalisées
          </li>
          <li class="flex items-center gap-2.5 text-sm text-[#9B99AA]">
            <svg class="w-4 h-4 text-[#7C3AED] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Rapport mensuel
          </li>
        </ul>
        <a href="#contact" class="block text-center bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-medium py-3 rounded-lg transition-colors text-sm">
          Demander un devis
        </a>
      </div>

      <div class="bg-[#110833] border border-[rgba(124,58,237,0.2)] rounded-xl p-8">
        <h3 class="font-syne font-bold text-lg text-[#F1F0F7] mb-1">Premium</h3>
        <p class="text-[#9B99AA] text-sm mb-6">Infogérance totale</p>
        <div class="mb-6">
          <span class="text-3xl font-syne font-extrabold text-[#F1F0F7]">Sur devis</span>
          <p class="text-[#9B99AA] text-xs mt-1">SLA garanti</p>
        </div>
