---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Collaboration en entreprise — ERP & CRM à La Réunion — Gigarun" description="ERP & CRM pour PME réunionnaises : centralisez ventes, clients, stocks et facturation dans Dolibarr, hébergé localement. Formation et support inclus.">
<section class="bg-[#07001C] pt-32 pb-16">
  <div class="max-w-5xl mx-auto px-6">
    <a href="/solutions" class="text-[#9B99AA] hover:text-[#F1F0F7] text-sm">← Nos solutions</a>
    <h1 class="font-syne font-extrabold text-[#F1F0F7] mt-4 mb-5" style="font-size:clamp(32px,5vw,56px);line-height:1.1;">Collaboration en entreprise : ERP &amp; CRM</h1>
    <p class="text-[#9B99AA] text-lg max-w-2xl mb-8">Centralisez ventes, clients, stocks et gestion dans un outil unique. Fini les fichiers Excel éparpillés et les données en double.</p>
    <div class="flex flex-wrap gap-3">
      <a href="/contact" class="bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-medium px-6 py-3 rounded-full transition-colors">Structurer ma gestion</a>
      <a href="tel:+262692311191" class="border border-[rgba(255,255,255,0.2)] text-[#F1F0F7] hover:border-white font-medium px-6 py-3 rounded-full transition-colors">0692 31 11 91</a>
    </div>
  </div>
</section>
<section class="bg-[#0A0022] py-16">
  <div class="max-w-5xl mx-auto px-6 grid md:grid-cols-2 gap-6">
    <div class="bg-[#0D0028] border border-[rgba(124,58,237,0.15)] rounded-xl p-6">
      <h2 class="font-syne font-bold text-[#F1F0F7] mb-3">Ce qu'on met en place</h2>
      <ul class="text-[#9B99AA] text-sm space-y-2">
        <li>ERP / CRM Dolibarr hébergé localement</li>
        <li>Gestion commerciale, stocks, facturation</li>
        <li>Suivi clients et prospects (CRM)</li>
        <li>Hébergement local + sauvegarde</li>
      </ul>
    </div>
    <div class="bg-[#0D0028] border border-[rgba(124,58,237,0.15)] rounded-xl p-6">
      <h2 class="font-syne font-bold text-[#F1F0F7] mb-3">Bénéfices</h2>
      <ul class="text-[#9B99AA] text-sm space-y-2">
        <li>Une seule source de vérité partagée</li>
        <li>Accès multi-utilisateurs sécurisé</li>
        <li>Données hébergées localement</li>
        <li>Formation et support inclus</li>
      </ul>
    </div>
  </div>
</section>
<section class="bg-[#07001C] py-12">
  <div class="max-w-5xl mx-auto px-6">
    <p class="text-[#9B99AA] text-sm mb-3">À voir aussi :</p>
    <div class="flex flex-wrap gap-4 text-sm">
        <a href="/dolibarr" class="text-[#7C3AED] hover:underline">Dolibarr ERP/CRM</a>
        <a href="/erp-cloud-sur-mesure" class="text-[#7C3AED] hover:underline">ERP Cloud sur mesure</a>
        <a href="/microsoft-365" class="text-[#7C3AED] hover:underline">Microsoft 365</a>
    </div>
  </div>
</section>
</Layout>
