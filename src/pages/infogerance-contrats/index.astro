---
import Layout from '../../layouts/Layout.astro';

const contrats = [
  {
    code: "bronze", nom: "BRONZE", couleur: "#CD7F32",
    bg: "rgba(205,127,50,0.08)", border: "rgba(205,127,50,0.25)",
    prix: "dès 25€", unite: "/poste/mois",
    desc: "L'essentiel à distance pour l'entreprise déjà équipée : on surveille et on épaule votre informatique interne.",
    socle: null,
    features: [
      "Monitoring & supervision des équipements",
      "Support & assistance à distance",
      "Mises à jour de sécurité",
      "Rapport d'activité",
    ],
    recommande: false,
  },
  {
    code: "argent", nom: "ARGENT", couleur: "#9B9B9B",
    bg: "rgba(155,155,155,0.08)", border: "rgba(155,155,155,0.25)",
    prix: "dès 30€", unite: "/poste/mois",
    desc: "On ajoute le terrain : interventions et maintenance sur site, déplacements inclus.",
    socle: "Tout BRONZE, plus :",
    features: [
      "Interventions sur site",
      "Maintenance préventive sur site",
      "Supervision des sauvegardes",
      "Main d'œuvre & déplacements inclus",
    ],
    recommande: false,
  },
  {
    code: "or", nom: "OR", couleur: "#FFD700",
    bg: "rgba(255,215,0,0.08)", border: "rgba(255,215,0,0.35)",
    prix: "dès 35€", unite: "/poste/mois",
    desc: "La couverture complète avec pilotage : pièces, réseau et DSI externalisée.",
    socle: "Tout ARGENT, plus :",
    features: [
      "Pièces défectueuses remplacées",
      "Gestion réseau, périphériques & GSM",
      "DSI externalisée",
      "Support prioritaire",
    ],
    recommande: true,
  },
  {
    code: "platine", nom: "PLATINE", couleur: "#E5E4E2",
    bg: "rgba(229,228,226,0.06)", border: "rgba(229,228,226,0.3)",
    prix: "dès 40€", unite: "/poste/mois",
    desc: "Le niveau maximal, orienté sécurité et conformité : RSSI et XDR/SIEM inclus.",
    socle: "Tout OR, plus :",
    features: [
      "RSSI externalisé",
      "XDR + SIEM inclus (postes, serveurs, NAS)",
      "SOC / cyberdéfense 24/7 (option)",
      "Conformité NIS2 accompagnée",
    ],
    recommande: false,
  },
];
---
<Layout title="Contrats d'infogérance Bronze à Platine — Gigarun" description="Comprenez nos 4 niveaux de contrat d'infogérance à La Réunion : ce qui est inclus dans Bronze, Argent, Or et Platine, et à partir de quel tarif. Estimez">

<!-- HERO -->
<section class="relative bg-[#07001C] flex items-center justify-center overflow-hidden" style="min-height:55vh;">
  <div class="absolute pointer-events-none" style="bottom:-60px;left:50%;transform:translateX(-50%);width:700px;height:400px;background:rgba(124,58,237,0.15);border-radius:50%;filter:blur(120px);"></div>
  <div class="relative max-w-4xl mx-auto px-6 pt-36 pb-16 text-center">
    <div class="inline-flex items-center gap-2 bg-[#110833] border border-[rgba(124,58,237,0.35)] px-4 py-1.5 mb-8 rounded-full">
      <span class="w-2 h-2 bg-[#7C3AED] rounded-full"></span>
      <span class="text-[#9B99AA] text-sm font-medium">Niveaux de service · La Réunion</span>
    </div>
    <h1 class="font-syne font-extrabold text-[#F1F0F7] leading-tight mb-5" style="font-size:clamp(36px,5vw,60px);">
      Quatre niveaux de service,<br/>
      <span class="text-transparent bg-clip-text" style="background-image:linear-gradient(135deg,#7C3AED,#06B6D4);">un seul interlocuteur</span>
    </h1>
    <p class="text-[#9B99AA] text-lg max-w-2xl mx-auto mb-10">
      De la supervision à distance (Bronze) à la cyberdéfense managée (Platine). Chaque niveau <strong class="text-[#F1F0F7]">inclut le précédent</strong>. Tarifs <strong class="text-[#F1F0F7]">HT à l'unité</strong> — vous ne payez que votre parc réel.
    </p>
    <div class="flex flex-wrap gap-3 justify-center">
      <button type="button" data-open-wizard class="bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-medium px-6 py-3 rounded-full transition-colors">Quel niveau pour moi ? →</button>
      <a href="/devis/infogerance" class="border border-[rgba(255,255,255,0.2)] text-[#F1F0F7] hover:border-white font-medium px-6 py-3 rounded-full transition-colors">Estimer directement</a>
    </div>
  </div>
</section>

<!-- GRILLE CONTRATS -->
<section class="bg-[#0A0022] py-20">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
      {contrats.map(c => (
        <div class={`relative flex flex-col rounded-2xl p-6 border transition-all ${c.recommande ? 'ring-2 ring-[#FFD700] scale-105' : ''}`}
             style={`background:${c.bg};border-color:${c.border};`}>
          {c.recommande && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-[#FFD700] text-[#07001C] text-xs font-bold px-4 py-1 rounded-full whitespace-nowrap">
              ⭐ Le plus populaire
            </div>
          )}
          <div class="mb-4">
            <div class="text-xs font-bold uppercase tracking-widest mb-1" style={`color:${c.couleur};`}>Contrat</div>
            <div class="font-syne font-extrabold text-[#F1F0F7] text-2xl">{c.nom}</div>
            <div class="mt-2"><span class="font-syne font-bold text-[#F1F0F7] text-2xl">{c.prix}</span><span class="text-[#9B99AA] text-sm"> {c.unite}</span></div>
            <p class="text-[#9B99AA] text-sm mt-2 leading-relaxed">{c.desc}</p>
          </div>
          {c.socle && <div class="text-[11px] font-semibold uppercase tracking-wide mb-2" style={`color:${c.couleur};`}>{c.socle}</div>}
          <ul class="flex-1 space-y-2 mb-6">
            {c.features.map(f => (
              <li class="flex items-start gap-2 text-sm text-[#9B99AA]">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style={`color:${c.couleur};`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                {f}
              </li>
            ))}
          </ul>
          <a href={`/devis/infogerance/?tier=${c.code}`} class="block text-center text-sm font-medium py-2.5 rounded-full transition-colors border"
             style={`color:${c.couleur};border-color:${c.couleur};`}
             data-color={c.couleur}
             onmouseover="this.style.background=this.style.borderColor;this.style.color='#07001C'"
             onmouseout="this.style.background='transparent';this.style.color=this.dataset.color">
            Estimer ce niveau →
          </a>
        </div>
      ))}
    </div>
    <p class="text-center text-[#9B99AA] text-sm mt-8">
      Tarification <strong class="text-[#F1F0F7]">à l'unité</strong> (poste, serveur, NAS, périphérique, site) selon le niveau choisi.
      Remise dégressive jusqu'à <strong class="text-[#F1F0F7]">-10%</strong> avec engagement 36 mois.
      <a href="/devis/infogerance" class="text-[#7C3AED] hover:underline">Faites votre estimation en ligne →</a>
    </p>
  </div>
</section>

<!-- TABLEAU COMPARATIF -->
<section class="bg-[#07001C] py-20">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="font-syne font-bold text-[#F1F0F7] text-center mb-10" style="font-size:clamp(24px,3vw,36px);">Ce que couvre chaque niveau</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="text-[#F1F0F7]">
            <th class="text-left p-3 border-b border-[rgba(124,58,237,0.2)]">Prestation</th>
            <th class="p-3 border-b border-[rgba(124,58,237,0.2)]" style="color:#CD7F32;">Bronze</th>
            <th class="p-3 border-b border-[rgba(124,58,237,0.2)]" style="color:#9B9B9B;">Argent</th>
            <th class="p-3 border-b border-[rgba(124,58,237,0.2)]" style="color:#FFD700;">Or</th>
            <th class="p-3 border-b border-[rgba(124,58,237,0.2)]" style="color:#E5E4E2;">Platine</th>
          </tr>
        </thead>
        <tbody class="text-[#9B99AA]">
          {[
            ["Monitoring & supervision", 1,1,1,1],
            ["Support & assistance à distance", 1,1,1,1],
            ["Interventions sur site", 0,1,1,1],
            ["Maintenance préventive sur site", 0,1,1,1],
            ["Supervision des sauvegardes", 0,1,1,1],
            ["Pièces défectueuses remplacées", 0,0,1,1],
            ["Gestion réseau, périphériques & GSM", 0,0,1,1],
            ["DSI externalisée", 0,0,1,1],
            ["RSSI externalisé", 0,0,0,1],
            ["XDR + SIEM inclus", 0,0,0,1],
            ["Conformité NIS2 accompagnée", 0,0,0,1],
          ].map(row => (
            <tr class="border-b border-[rgba(124,58,237,0.08)]">
              <td class="p-3 text-left">{row[0]}</td>
              {[1,2,3,4].map(i => (
                <td class="p-3 text-center">{row[i] ? <span class="text-[#06B6D4] font-bold">✓</span> : <span class="text-[#3a3550]">—</span>}</td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="bg-[#0A0022] py-16">
  <div class="max-w-2xl mx-auto px-6 text-center">
    <h2 class="font-syne font-bold text-[#F1F0F7] mb-4" style="font-size:clamp(22px,3vw,36px);">Quel niveau pour votre entreprise ?</h2>
    <p class="text-[#9B99AA] mb-8">Répondez à 3 questions et on vous recommande le niveau adapté, avec une estimation chiffrée à la clé.</p>
    <div class="flex flex-wrap gap-3 justify-center">
      <button type="button" data-open-wizard class="inline-flex items-center gap-2 bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-medium px-7 py-3 rounded-full transition-colors">Trouver mon niveau →</button>
      <a href="/contact" class="inline-flex items-center gap-2 border border-[rgba(255,255,255,0.2)] text-[#F1F0F7] hover:border-white font-medium px-7 py-3 rounded-full transition-colors">Diagnostic gratuit</a>
    </div>
  </div>
</section>

<!-- WIZARD MODALE -->
<div id="wizard-overlay" class="fixed inset-0 z-[100] items-center justify-center p-4" style="display:none;background:rgba(7,0,28,0.88);backdrop-filter:blur(2px);">
  <div class="bg-[#0D0028] border border-[rgba(124,58,237,0.3)] rounded-2xl max-w-md w-full p-7 relative">
    <button type="button" id="wizard-close" aria-label="Fermer" class="absolute top-3 right-4 text-[#9B99AA] hover:text-white text-2xl leading-none">×</button>
    <h3 class="font-syne font-bold text-[#F1F0F7] text-xl mb-1">Trouvons votre niveau</h3>
    <p id="wizard-progress" class="text-[#7C3AED] text-xs font-medium mb-5">Question 1 / 3</p>
    <div id="wizard-question"></div>
    <div id="wizard-result" class="hidden"></div>
  </div>
</div>

<script>
  const TIERS = {
    bronze:  { nom: 'BRONZE',  raison: "Vous avez déjà une informatique gérée en interne (technicien, outils, sauvegardes). GiGaRuN intervient en supervision et support à distance, en filet de sécurité." },
    argent:  { nom: 'ARGENT',  raison: "Vous avez besoin de nous sur le terrain — interventions et maintenance sur site, sauvegardes supervisées — sans pilotage stratégique." },
    or:      { nom: 'OR',      raison: "Vous confiez le pilotage complet de votre IT à GiGaRuN (DSI externalisée : conseil, réseau, matériel). C'est notre formule la plus choisie." },
    platine: { nom: 'PLATINE', raison: "En plus du pilotage complet, votre activité a des enjeux de cybersécurité et de conformité (RSSI, XDR/SIEM, accompagnement NIS2)." },
  };
  const QUESTIONS = [
    { q: "Avez-vous déjà une informatique gérée en interne — un technicien, des outils de sécurité et des sauvegardes en place ?",
      a: [ { label: "Oui, on est autonomes au quotidien", next: 'r:bronze' }, { label: "Non, on a besoin de vous sur le terrain", next: 1 } ] },
    { q: "Souhaitez-vous que GiGaRuN pilote votre informatique — conseil, gestion du réseau et des équipements, remplacement du matériel ?",
      a: [ { label: "Non, juste la maintenance et le dépannage", next: 'r:argent' }, { label: "Oui, soyez notre DSI externalisée", next: 2 } ] },
    { q: "Votre activité traite-t-elle des données sensibles, ou relève-t-elle d'un secteur encadré (santé, public, collectivité, finance, énergie… ou sous-traitant de ces secteurs) ?",
      a: [ { label: "Non", next: 'r:or' }, { label: "Oui, ou je ne suis pas sûr", next: 'r:platine' } ] },
  ];

  const overlay = document.getElementById('wizard-overlay');
  const qBox = document.getElementById('wizard-question');
  const rBox = document.getElementById('wizard-result');
  const prog = document.getElementById('wizard-progress');

  function openWizard() { renderStep(0); overlay.style.display = 'flex'; }
  function closeWizard() { overlay.style.display = 'none'; }

  function renderStep(i) {
    rBox.classList.add('hidden'); qBox.classList.remove('hidden');
    prog.textContent = 'Question ' + (i + 1) + ' / 3';
    const Q = QUESTIONS[i];
    qBox.innerHTML = '<p class="text-[#F1F0F7] text-sm mb-5 leading-relaxed">' + Q.q + '</p>';
    Q.a.forEach((opt) => {
      const b = document.createElement('button');
      b.type = 'button';
      b.className = 'w-full text-left bg-[#07001C] border border-[rgba(124,58,237,0.3)] hover:border-[#7C3AED] text-[#F1F0F7] text-sm rounded-lg px-4 py-3 mb-2 transition-all';
      b.textContent = opt.label;
      b.addEventListener('click', () => {
        if (typeof opt.next === 'string' && opt.next.startsWith('r:')) showResult(opt.next.slice(2));
        else renderStep(opt.next);
      });
      qBox.appendChild(b);
    });
  }

  function showResult(code) {
    const t = TIERS[code];
    qBox.classList.add('hidden'); rBox.classList.remove('hidden');
    prog.textContent = 'Notre recommandation';
    rBox.innerHTML =
      '<div class="text-center mb-4"><div class="text-[#9B99AA] text-xs uppercase tracking-widest mb-1">Il vous faut le contrat</div>' +
      '<div class="font-syne font-extrabold text-[#7C3AED] text-3xl">' + t.nom + '</div></div>' +
      '<p class="text-[#9B99AA] text-sm leading-relaxed mb-6">' + t.raison + '</p>' +
      '<a href="/devis/infogerance/?tier=' + code + '" class="block text-center bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-semibold py-3 rounded-lg transition-all">Estimer le contrat ' + t.nom + ' →</a>' +
      '<button type="button" id="wizard-restart" class="w-full text-[#9B99AA] hover:text-white text-xs mt-3">↻ Recommencer</button>';
    document.getElementById('wizard-restart').addEventListener('click', () => renderStep(0));
  }

  document.querySelectorAll('[data-open-wizard]').forEach((el) => el.addEventListener('click', openWizard));
  document.getElementById('wizard-close').addEventListener('click', closeWizard);
  overlay.addEventListener('click', (e) => { if (e.target === overlay) closeWizard(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeWizard(); });
</script>

</Layout>
