---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Expertise opérationnelle en informatique — Gigarun La Réunion" description="Expertise opérationnelle IT pour entreprises réunionnaises : renfort d'experts en infrastructure, systèmes, réseau et cloud, sur projet ou en continu, sans recruter.">
<section class="bg-[#07001C] pt-32 pb-16">
  <div class="max-w-5xl mx-auto px-6">
    <a href="/services" class="text-[#9B99AA] hover:text-[#F1F0F7] text-sm">← Nos services</a>
    <h1 class="font-syne font-extrabold text-[#F1F0F7] mt-4 mb-5" style="font-size:clamp(32px,5vw,56px);line-height:1.1;">Expertise opérationnelle</h1>
    <p class="text-[#9B99AA] text-lg max-w-2xl mb-8">Un renfort d'experts pour vos projets et votre exploitation au quotidien : infrastructure, systèmes, réseau, cloud — sans avoir à recruter.</p>
    <div class="flex flex-wrap gap-3">
      <a href="/contact" class="bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-medium px-6 py-3 rounded-full transition-colors">Renforcer mon équipe</a>
      <a href="tel:+262692311191" class="border border-[rgba(255,255,255,0.2)] text-[#F1F0F7] hover:border-white font-medium px-6 py-3 rounded-full transition-colors">0692 31 11 91</a>
    </div>
  </div>
</section>
<section class="bg-[#0A0022] py-16">
  <div class="max-w-5xl mx-auto px-6 grid md:grid-cols-2 gap-6">
    <div class="bg-[#0D0028] border border-[rgba(124,58,237,0.15)] rounded-xl p-6">
      <h2 class="font-syne font-bold text-[#F1F0F7] mb-3">Nos compétences</h2>
      <ul class="text-[#9B99AA] text-sm space-y-2">
        <li>Ingénierie d'infrastructure</li>
        <li>Administration systèmes et réseau</li>
        <li>Migration et déploiement</li>
        <li>Renfort ponctuel ou récurrent</li>
      </ul>
    </div>
    <div class="bg-[#0D0028] border border-[rgba(124,58,237,0.15)] rounded-xl p-6">
      <h2 class="font-syne font-bold text-[#F1F0F7] mb-3">Bénéfices</h2>
      <ul class="text-[#9B99AA] text-sm space-y-2">
        <li>Des compétences pointues à la demande</li>
        <li>Sans alourdir votre masse salariale</li>
        <li>Transfert de compétences à vos équipes</li>
        <li>Taux horaire transparent</li>
      </ul>
    </div>
  </div>
</section>
<section class="bg-[#07001C] py-12">
  <div class="max-w-5xl mx-auto px-6">
    <p class="text-[#9B99AA] text-sm mb-3">À voir aussi :</p>
    <div class="flex flex-wrap gap-4 text-sm">
        <a href="/infogerance" class="text-[#7C3AED] hover:underline">Infogérance</a>
        <a href="/audit" class="text-[#7C3AED] hover:underline">Audit informatique</a>
        <a href="/reseau" class="text-[#7C3AED] hover:underline">Réseau</a>
    </div>
  </div>
</section>
</Layout>
