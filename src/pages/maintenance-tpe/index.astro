---
import Layout from '../../layouts/Layout.astro';
---
<Layout>
<section class="bg-[#07001C] pt-32 pb-20">
  <div class="max-w-6xl mx-auto px-6">
    <div class="max-w-3xl mb-16">
      <h1 class="font-syne font-extrabold text-[#F1F0F7] mb-6" style="font-size:clamp(32px,5vw,56px);line-height:1.1;">Maintenance informatique pour TPE a La Reunion</h1>
      <p class="text-[#9B99AA] text-lg leading-relaxed mb-8">Vous n&#39;avez pas de service informatique interne ? Gigarun joue le role de votre DSI externe. Maintenance preventive, support, securite — a partir de 99 EUR/mois.</p>
      <a href="tel:+262692311191" class="bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-semibold px-6 py-3 rounded-lg transition-all inline-block">0692 31 11 91 — Devis gratuit</a>
    </div>
    <div class="bg-[#0A0022] border border-[rgba(124,58,237,0.2)] rounded-2xl p-8 mb-12">
      <h2 class="font-syne font-bold text-[#F1F0F7] text-2xl mb-6">Offres maintenance TPE</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-[#0D0028] rounded-xl p-6">
          <h3 class="font-syne font-bold text-[#F1F0F7] mb-2">Essentiel</h3>
          <div class="text-[#7C3AED] font-bold text-2xl mb-3">99 EUR<span class="text-sm font-normal text-[#9B99AA]">/mois</span></div>
          <ul class="text-[#9B99AA] text-sm space-y-2">
            <li>Jusqu&#39;a 5 postes</li>
            <li>Supervision 24/7</li>
            <li>Support a distance illimite</li>
            <li>Mises a jour securite</li>
          </ul>
        </div>
        <div class="bg-[#0D0028] rounded-xl p-6 border border-[#7C3AED]">
          <h3 class="font-syne font-bold text-[#F1F0F7] mb-2">Business <span class="text-xs bg-[#7C3AED] px-2 py-0.5 rounded-full">Populaire</span></h3>
          <div class="text-[#7C3AED] font-bold text-2xl mb-3">199 EUR<span class="text-sm font-normal text-[#9B99AA]">/mois</span></div>
          <ul class="text-[#9B99AA] text-sm space-y-2">
            <li>Jusqu&#39;a 15 postes</li>
            <li>Supervision 24/7</li>
            <li>Support a distance + interventions</li>
            <li>Sauvegardes gerees</li>
            <li>Rapport mensuel</li>
          </ul>
        </div>
        <div class="bg-[#0D0028] rounded-xl p-6">
          <h3 class="font-syne font-bold text-[#F1F0F7] mb-2">Premium</h3>
          <div class="text-[#7C3AED] font-bold text-2xl mb-3">Sur devis</div>
          <ul class="text-[#9B99AA] text-sm space-y-2">
            <li>Parc illimite</li>
            <li>SLA garantis</li>
            <li>Astreinte week-end</li>
            <li>DSI temps partiel dedie</li>
          </ul>
        </div>
      </div>
    </div>
    <div class="bg-[#0D0028] border border-[rgba(124,58,237,0.2)] rounded-xl p-6 max-w-xl">
      <h3 class="text-white font-semibold mb-2">Pas sur de quel forfait vous avez besoin ?</h3>
      <p class="text-[#9B99AA] text-sm mb-4">Audit gratuit — on dimensionne le bon forfait pour votre structure.</p>
      <a href="tel:+262692311191" class="bg-[#7C3AED] hover:bg-[#6D28D9] text-white text-sm font-medium px-5 py-2.5 rounded-lg transition-all inline-block">0692 31 11 91</a>
    </div>
  </div>
</section>
</Layout>
