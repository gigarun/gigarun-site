---
import Layout from '../../layouts/Layout.astro';
---
<Layout>
<section class="bg-[#07001C] pt-32 pb-20">
  <div class="max-w-6xl mx-auto px-6">
    <div class="max-w-3xl mb-16">
      <h1 class="font-syne font-extrabold text-[#F1F0F7] mb-4" style="font-size:clamp(32px,5vw,56px);line-height:1.1;">Contactez Gigarun</h1>
      <p class="text-[#9B99AA] text-lg">On vous repond sous 24h en semaine. Pour les urgences, appelez directement.</p>
    </div>
    <div class="grid md:grid-cols-2 gap-12">
      <div>
        <div class="space-y-6 mb-8">
          <div class="flex items-start gap-4">
            <div class="bg-[#110833] border border-[rgba(124,58,237,0.3)] rounded-lg p-3 flex-shrink-0">
              <svg class="w-5 h-5 text-[#7C3AED]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            </div>
            <div>
              <div class="text-[#F1F0F7] font-semibold">Telephone</div>
              <a href="tel:+262692311191" class="text-[#7C3AED] text-lg font-bold">0692 31 11 91</a>
              <div class="text-[#9B99AA] text-xs mt-1">Lun-Ven 8h-18h — Urgences 24/7 pour clients sous contrat</div>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="bg-[#110833] border border-[rgba(124,58,237,0.3)] rounded-lg p-3 flex-shrink-0">
              <svg class="w-5 h-5 text-[#7C3AED]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <div class="text-[#F1F0F7] font-semibold">Email</div>
              <a href="mailto:contact@gigarun.net" class="text-[#7C3AED]">contact@gigarun.net</a>
              <div class="text-[#9B99AA] text-xs mt-1">Reponse sous 24h en semaine</div>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="bg-[#110833] border border-[rgba(124,58,237,0.3)] rounded-lg p-3 flex-shrink-0">
              <svg class="w-5 h-5 text-[#7C3AED]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <div>
              <div class="text-[#F1F0F7] font-semibold">Adresse</div>
              <div class="text-[#9B99AA]">Saint-Pierre, La Reunion (974)</div>
              <div class="text-[#9B99AA] text-xs mt-1">Interventions sur toute l&#39;ile</div>
            </div>
          </div>
        </div>
      </div>
      <div class="bg-[#0D0028] border border-[rgba(124,58,237,0.15)] rounded-2xl p-8">
        <h2 class="font-syne font-bold text-[#F1F0F7] text-xl mb-6">Envoyer un message</h2>
        <form class="space-y-4" name="contact" method="POST">
          <div>
            <label class="text-[#9B99AA] text-sm block mb-1">Votre nom</label>
            <input type="text" name="nom" class="w-full bg-[#07001C] border border-[rgba(124,58,237,0.3)] text-[#F1F0F7] rounded-lg px-4 py-2.5 focus:outline-none focus:border-[#7C3AED]" />
          </div>
          <div>
            <label class="text-[#9B99AA] text-sm block mb-1">Email ou telephone</label>
            <input type="text" name="contact" class="w-full bg-[#07001C] border border-[rgba(124,58,237,0.3)] text-[#F1F0F7] rounded-lg px-4 py-2.5 focus:outline-none focus:border-[#7C3AED]" />
          </div>
          <div>
            <label class="text-[#9B99AA] text-sm block mb-1">Votre message</label>
            <textarea name="message" rows="4" class="w-full bg-[#07001C] border border-[rgba(124,58,237,0.3)] text-[#F1F0F7] rounded-lg px-4 py-2.5 focus:outline-none focus:border-[#7C3AED]"></textarea>
          </div>
          <button type="submit" class="w-full bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-semibold py-3 rounded-lg transition-all">Envoyer</button>
        </form>
      </div>
    </div>
  </div>
</section>
</Layout>
