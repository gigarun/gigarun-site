---
import Layout from '../../layouts/Layout.astro';

const tabs = [
  { id: 'tous', label: 'Tous', cats: [], types: [] },
  { id: 'cyber', label: 'Cybersécurité', cats: ['Cybersécurité','Sécurité','Sécurité email','NIS2'], types: [] },
  { id: 'infogerance', label: 'Infogérance', cats: ['Infogérance','Support IT','Expertise IT','Gestion IT'], types: [] },
  { id: 'infra', label: 'Infrastructure', cats: ['Infrastructure','Cloud','Sauvegarde'], types: [] },
  { id: 'm365', label: 'Microsoft 365', cats: ['Microsoft 365','Messagerie'], types: [] },
  { id: 'solutions', label: 'Solutions', cats: ['Location matériel','Téléphonie','E-Commerce'], types: [] },
  { id: 'ia', label: 'IA', cats: ['Intelligence artificielle'], types: [] },
  { id: 'gigarun', label: 'Gigarun', cats: ['Gigarun','Numérique responsable'], types: [] },
  { id: 'guides', label: '📘 Guides pratiques', cats: [], types: ['guide'] },
];
---
<Layout title="Blog & Guides IT — Gigarun La Réunion" description="Articles, conseils pratiques et guides techniques pour les PME et TPE réunionnaises. Cybersécurité, infogérance, Microsoft 365, IA et plus.">
<section class="bg-[#07001C] pt-32 pb-20">
  <div class="max-w-6xl mx-auto px-6">

    <div class="max-w-2xl mb-10">
      <div class="inline-flex items-center gap-2 bg-[#110833] border border-[rgba(124,58,237,0.35)] px-4 py-1.5 mb-6 rounded-full">
        <span class="w-2 h-2 bg-[#7C3AED] rounded-full"></span>
        <span class="text-[#9B99AA] text-sm font-medium" id="blog-count">Blog & Guides · 69 ressources</span>
      </div>
      <h1 class="font-syne font-extrabold text-[#F1F0F7] mb-4" style="font-size:clamp(32px,5vw,48px);line-height:1.1;">Ressources IT pour<br/>les PME réunionnaises</h1>
      <p class="text-[#9B99AA] text-lg">Articles de fond, guides pratiques pas-à-pas et analyses pour les dirigeants et équipes IT de La Réunion.</p>
    </div>

    <div class="flex flex-wrap gap-2 mb-10" id="blog-tabs" role="tablist">
      {tabs.map((tab, i) => (
        <button
          role="tab"
          data-tab={tab.id}
          data-cats={JSON.stringify(tab.cats)}
          data-types={JSON.stringify(tab.types)}
          class={`tab-btn px-4 py-2 rounded-full text-sm font-medium transition-all border ${i === 0 ? 'bg-[#7C3AED] border-[#7C3AED] text-white' : 'bg-transparent border-[rgba(124,58,237,0.3)] text-[#9B99AA] hover:border-[#7C3AED] hover:text-[#F1F0F7]'}`}
          aria-selected={i === 0 ? 'true' : 'false'}>
          {tab.label}
        </button>
      ))}
    </div>

    <div class="grid md:grid-cols-3 gap-6" id="blog-grid">
    </div>
    <p id="blog-empty" class="hidden text-center text-[#9B99AA] py-16">Aucune ressource dans cette catégorie.</p>
  </div>
</section>

<button id="back-to-top" title="Remonter en haut"
  style="position:fixed;bottom:2rem;right:2rem;z-index:50;width:44px;height:44px;border-radius:50%;background:#7C3AED;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(124,58,237,0.4);opacity:0;pointer-events:none;transition:opacity 0.25s,transform 0.25s;transform:translateY(8px);">
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/>
  </svg>
</button>

