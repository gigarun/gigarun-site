const grid = document.getElementById('blog-grid');
const countEl = document.getElementById('blog-count');
const emptyEl = document.getElementById('blog-empty');
const tabs = document.querySelectorAll('.tab-btn');

function renderItems(items) {
  grid.innerHTML = items.map(a => `
    <a href="${a.href}" data-cat="${a.cat}" data-type="${a.type}"
       class="article-card bg-[#0D0028] border border-[rgba(124,58,237,0.15)] rounded-xl p-6 hover:border-[#7C3AED] transition-all block group">
      <div class="flex items-center gap-2 mb-3 flex-wrap">
        <span class="bg-[#110833] border border-[rgba(124,58,237,0.3)] text-[#7C3AED] text-[10px] font-medium px-2 py-0.5 rounded-full">${a.cat}</span>
        ${a.type === 'guide' ? '<span style="background:rgba(6,182,212,0.15);border:1px solid rgba(6,182,212,0.35);color:#06B6D4;font-size:10px;font-weight:600;padding:1px 8px;border-radius:9999px;">Guide</span>' : ''}
        ${a.date ? `<span class="text-[#9B99AA] text-xs">${a.date}</span>` : ''}
      </div>
      <h2 class="font-syne font-bold text-[#F1F0F7] text-sm leading-snug mb-2 group-hover:text-[#7C3AED] transition-colors">${a.titre}</h2>
      <p class="text-[#9B99AA] text-xs leading-relaxed">${a.desc}</p>
    </a>`).join('');
}

function filterAndRender(cats, types) {
  let items = ALL_ITEMS.filter(a => {
    const catOk = cats.length === 0 || cats.includes(a.cat);
    const typeOk = types.length === 0 || types.includes(a.type);
    return catOk && typeOk;
  });
  renderItems(items);
  countEl.textContent = `Blog & Guides · ${items.length} ressource${items.length > 1 ? 's' : ''}`;
  emptyEl.classList.toggle('hidden', items.length > 0);
}

// Init : afficher tout
// Activer onglet depuis URL ?tab=
const urlTab = new URLSearchParams(window.location.search).get('tab');
if (urlTab) {
  const target = document.querySelector(`.tab-btn[data-tab="${urlTab}"]`);
  if (target) target.click();
} else {
  renderItems(ALL_ITEMS);
}

tabs.forEach(tab => {
  tab.addEventListener('click', () => {
    tabs.forEach(t => {
      t.classList.remove('bg-[#7C3AED]','border-[#7C3AED]','text-white');
      t.classList.add('bg-transparent','border-[rgba(124,58,237,0.3)]','text-[#9B99AA]');
      t.setAttribute('aria-selected','false');
    });
    tab.classList.add('bg-[#7C3AED]','border-[#7C3AED]','text-white');
    tab.classList.remove('bg-transparent','border-[rgba(124,58,237,0.3)]','text-[#9B99AA]');
    tab.setAttribute('aria-selected','true');
    const cats = JSON.parse(tab.dataset.cats || '[]');
    const types = JSON.parse(tab.dataset.types || '[]');
    filterAndRender(cats, types);
  });
});

// Bouton retour en haut
const btn = document.getElementById('back-to-top');
window.addEventListener('scroll', () => {
  const show = window.scrollY > 400;
  btn.style.opacity = show ? '1' : '0';
  btn.style.pointerEvents = show ? 'auto' : 'none';
  btn.style.transform = show ? 'translateY(0)' : 'translateY(8px)';
}, { passive: true });
btn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
</script>
</Layout>
