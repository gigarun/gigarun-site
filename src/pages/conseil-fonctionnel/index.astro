---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Conseil fonctionnel en informatique à La Réunion — Gigarun" description="Conseil fonctionnel en informatique pour PME réunionnaises : aligner l'IT sur vos métiers, choix fonctionnel des outils (ERP, CRM), optimisation des processus, conduite du changement.">
<section class="bg-[#07001C] pt-32 pb-16">
  <div class="max-w-5xl mx-auto px-6">
    <a href="/services" class="text-[#9B99AA] hover:text-[#F1F0F7] text-sm">← Nos services</a>
    <h1 class="font-syne font-extrabold text-[#F1F0F7] mt-4 mb-5" style="font-size:clamp(32px,5vw,56px);line-height:1.1;">Conseil fonctionnel en informatique</h1>
    <p class="text-[#9B99AA] text-lg max-w-2xl mb-8">Aligner l'informatique sur vos métiers : on traduit vos besoins réels en solutions concrètes et on optimise vos processus.</p>
    <div class="flex flex-wrap gap-3">
      <a href="/contact" class="bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-medium px-6 py-3 rounded-full transition-colors">Optimiser mon SI</a>
      <a href="tel:+262692311191" class="border border-[rgba(255,255,255,0.2)] text-[#F1F0F7] hover:border-white font-medium px-6 py-3 rounded-full transition-colors">0692 31 11 91</a>
    </div>
  </div>
</section>
<section class="bg-[#0A0022] py-16">
  <div class="max-w-5xl mx-auto px-6 grid md:grid-cols-2 gap-6">
    <div class="bg-[#0D0028] border border-[rgba(124,58,237,0.15)] rounded-xl p-6">
      <h2 class="font-syne font-bold text-[#F1F0F7] mb-3">Notre approche</h2>
      <ul class="text-[#9B99AA] text-sm space-y-2">
        <li>Analyse des besoins métier</li>
        <li>Choix fonctionnel des outils (ERP, CRM, collaboratif)</li>
        <li>Optimisation et automatisation des processus</li>
        <li>Conduite du changement</li>
      </ul>
    </div>
    <div class="bg-[#0D0028] border border-[rgba(124,58,237,0.15)] rounded-xl p-6">
      <h2 class="font-syne font-bold text-[#F1F0F7] mb-3">Bénéfices</h2>
      <ul class="text-[#9B99AA] text-sm space-y-2">
        <li>Des outils qui servent vraiment vos équipes</li>
        <li>Moins de tâches manuelles et de ressaisies</li>
        <li>Adoption facilitée par les utilisateurs</li>
        <li>Un ROI mesurable</li>
      </ul>
    </div>
  </div>
</section>
<section class="bg-[#07001C] py-12">
  <div class="max-w-5xl mx-auto px-6">
    <p class="text-[#9B99AA] text-sm mb-3">À voir aussi :</p>
    <div class="flex flex-wrap gap-4 text-sm">
        <a href="/collaboration-erp-crm" class="text-[#7C3AED] hover:underline">ERP &amp; CRM</a>
        <a href="/dolibarr" class="text-[#7C3AED] hover:underline">Dolibarr</a>
        <a href="/conseil-solutions-informatiques" class="text-[#7C3AED] hover:underline">Conseil en solutions</a>
    </div>
  </div>
</section>
</Layout>
